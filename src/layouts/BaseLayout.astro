---
import '../styles/global.css';
import ReportModal from '../components/ReportModal.astro';
import Analytics from '@vercel/analytics/astro';

interface Props {
	title?: string;
}

const { title = "Ing. Informática Tests UA" } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<title>{title}</title>
		<link rel="icon" type="image/png" href="/resources/images/logo.png" />
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;500;600&family=Outfit:wght@500;600;700;800&display=swap" rel="stylesheet">

		<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
		<link rel="stylesheet" href="/resources/css/prism.css" />
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.13.0/katex.min.css" crossorigin="anonymous" />
		<script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
		
		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();

			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
		</script>
	</head>
	<body class="min-h-screen bg-background text-text-main flex justify-center pt-[90px] pb-[40px] m-0 box-border">
		<div id="app-shell" class="w-full">
		<header class="fixed top-0 left-0 right-0 z-50 flex justify-between items-center bg-surface px-5 py-2.5 shadow-sm border-b border-border-subtle transition-colors backdrop-blur-md bg-opacity-90">
			
			<a href="https://github.com/informaticatestua/Informatica-Test-UA" class="inline-block p-2 mr-2 text-text-muted hover:text-text-main hover:bg-surface-hover rounded-full transition-colors" target="_blank" rel="noopener noreferrer">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
					<path d="M12 1.27a11 11 0 00-3.48 21.46c.55.09.73-.28.73-.55v-1.84c-3.03.64-3.67-1.46-3.67-1.46-.55-1.29-1.28-1.65-1.28-1.65-.92-.65.1-.65.1-.65 1.1 0 1.73 1.1 1.73 1.1.92 1.65 2.57 1.2 3.21.92a2 2 0 01.64-1.47c-2.47-.27-5.04-1.19-5.04-5.5 0-1.1.46-2.1 1.2-2.84a3.76 3.76 0 010-2.93s.91-.28 3.11 1.1c1.8-.49 3.7-.49 5.5 0 2.1-1.38 3.02-1.1 3.02-1.1a3.76 3.76 0 010 2.93c.83.74 1.2 1.74 1.2 2.94 0 4.21-2.57 5.13-5.04 5.4.45.37.82.92.82 2.02v3.03c0 .27.1.64.73.55A11 11 0 0012 1.27"></path>
				</svg>
			</a>

			<h2 id="asignatura-nombre" class="m-0 text-center flex-grow pl-[10px] flex items-center justify-center gap-3 flex-wrap cursor-pointer" onclick="window.location.href = '/'">
				<span class="title-main font-heading font-extrabold tracking-wide text-black dark:text-white">
					Ing. Informática Tests UA
				</span>
			</h2>



			<div class="ml-auto flex items-center gap-1">
				<button id="ai-settings-btn" class="mt-1 p-2 text-text-muted hover:text-blue-500 bg-transparent border-none rounded-full transition-colors cursor-pointer flex items-center justify-center" aria-label="Configuración de IA">
					<span class="material-icons" style="font-size: 1.2em;">auto_awesome</span>
				</button>
				<button id="theme-toggle" class="mt-1 p-2 text-text-muted hover:text-blue-500 bg-transparent border-none rounded-full transition-colors cursor-pointer flex items-center justify-center" aria-label="Cambiar tema">
					<span class="material-icons" id="theme-icon" style="font-size: 1.2em;">light_mode</span>
				</button>
			</div>
		</header>

		<!-- ─── AI Settings overlay ──────────────────────────────────────────── -->
		<div id="ai-settings-overlay" class="hidden fixed inset-0 z-[300] bg-black/60 backdrop-blur-sm"></div>

		<!-- ─── AI Settings modal ────────────────────────────────────────────── -->
		<div id="ai-settings-modal" class="hidden fixed inset-0 z-[301] flex items-center justify-center p-4">
			<div class="ai-settings-box w-full max-w-md bg-surface rounded-2xl shadow-2xl border border-border-subtle overflow-hidden">
				<div class="h-1 w-full bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500"></div>
				<div class="p-6">
					<div class="flex items-center justify-between mb-5">
						<div class="flex items-center gap-2">
							<span class="material-icons text-blue-500">auto_awesome</span>
							<h3 class="font-heading font-bold text-text-main text-lg m-0">Configuración de IA</h3>
						</div>
						<button id="ai-settings-close" class="p-1 text-text-muted hover:text-text-main rounded-full hover:bg-surface-hover transition-colors cursor-pointer border-none bg-transparent" aria-label="Cerrar">
							<span class="material-icons">close</span>
						</button>
					</div>

					<!-- Aviso sin clave configurada -->
					<div id="ai-settings-no-key-msg" class="hidden mb-4 p-3 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-300 dark:border-yellow-700 rounded-lg text-yellow-800 dark:text-yellow-300 text-sm">
						Configura una API Key para usar las explicaciones de IA.
					</div>

					<!-- Selección de proveedor -->
					<p class="text-text-muted text-xs font-semibold uppercase tracking-wider mb-3">Proveedor activo</p>
					<div class="grid grid-cols-3 gap-2 mb-5">
						<label class="ai-provider-card">
							<input type="radio" name="ai-provider" value="gemini" class="sr-only">
							<span class="material-icons text-blue-500" style="font-size:1.5rem;">auto_awesome</span>
							<span class="text-xs font-semibold text-text-main">Gemini</span>
						</label>
						<label class="ai-provider-card">
							<input type="radio" name="ai-provider" value="groq" class="sr-only">
							<span class="text-orange-500 font-bold leading-none" style="font-size:1.5rem;">⚡</span>
							<span class="text-xs font-semibold text-text-main">Groq</span>
						</label>
						<label class="ai-provider-card">
							<input type="radio" name="ai-provider" value="deepseek" class="sr-only">
							<span class="text-blue-400 font-bold leading-none" style="font-size:1.5rem;">🐋</span>
							<span class="text-xs font-semibold text-text-main">DeepSeek</span>
						</label>
					</div>

					<!-- Gemini config -->
					<div id="ai-gemini-config" class="space-y-3">
						<div>
							<label class="block text-sm font-medium text-text-main mb-1" for="ai-gemini-key">API Key de Google Gemini</label>
							<input id="ai-gemini-key" type="password" placeholder="AIza..." class="ai-input" autocomplete="off" />
						</div>
						<div>
							<label class="block text-sm font-medium text-text-main mb-1" for="ai-gemini-model">Modelo</label>
							<select id="ai-gemini-model" class="ai-select">
								<option value="gemini-2.0-flash">gemini-2.0-flash</option>
								<option value="gemini-2.5-flash">gemini-2.5-flash</option>
								<option value="gemini-1.5-pro">gemini-1.5-pro</option>
							</select>
						</div>
					</div>

					<!-- Groq config -->
					<div id="ai-groq-config" class="hidden space-y-3">
						<div>
							<label class="block text-sm font-medium text-text-main mb-1" for="ai-groq-key">API Key de Groq</label>
							<input id="ai-groq-key" type="password" placeholder="gsk_..." class="ai-input" autocomplete="off" />
						</div>
						<div>
							<label class="block text-sm font-medium text-text-main mb-1" for="ai-groq-model">Modelo</label>
							<select id="ai-groq-model" class="ai-select">
								<option value="llama-3.3-70b-versatile">llama-3.3-70b-versatile</option>
								<option value="deepseek-r1-distill-llama-70b">deepseek-r1-distill-llama-70b</option>
								<option value="llama-3.1-8b-instant">llama-3.1-8b-instant (rápido)</option>
							</select>
						</div>
					</div>

					<!-- DeepSeek config -->
					<div id="ai-deepseek-config" class="hidden space-y-3">
						<div>
							<label class="block text-sm font-medium text-text-main mb-1" for="ai-deepseek-key">API Key de DeepSeek</label>
							<input id="ai-deepseek-key" type="password" placeholder="sk-..." class="ai-input" autocomplete="off" />
						</div>
						<div>
							<label class="block text-sm font-medium text-text-main mb-1" for="ai-deepseek-model">Modelo</label>
							<select id="ai-deepseek-model" class="ai-select">
								<option value="deepseek-chat">deepseek-chat</option>
								<option value="deepseek-reasoner">deepseek-reasoner</option>
							</select>
						</div>
					</div>

					<div class="mt-6 flex justify-end">
						<button id="ai-settings-save" class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-semibold transition-colors cursor-pointer border-none">
							Guardar y aplicar
						</button>
					</div>
				</div>
			</div>
		</div>

		<ReportModal />

		<main class="w-full">
			<slot />
		</main>
		</div>

		<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.13.0/katex.min.js" crossorigin="anonymous"></script>
		<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.13.0/contrib/auto-render.min.js" crossorigin="anonymous"></script>
		
		<script>
			const themeToggle = document.getElementById("theme-toggle");
			const themeIcon = document.getElementById("theme-icon");
			
			const updateIcon = (isDark) => {
				if (themeIcon) {
					themeIcon.innerText = isDark ? "dark_mode" : "light_mode";
				}
			};

			const handleToggleClick = () => {
				const element = document.documentElement;
				element.classList.toggle("dark");
				const isDark = element.classList.contains("dark");
				localStorage.setItem("theme", isDark ? "dark" : "light");
				updateIcon(isDark);
			};

			if (themeToggle) {
				updateIcon(document.documentElement.classList.contains("dark"));
				themeToggle.addEventListener("click", handleToggleClick);
			}

		</script>
		
		<script is:inline src="/resources/js/prism.js"></script>
		<script is:inline src="/resources/js/formatters.js"></script>
		<script is:inline src="/resources/js/main.js"></script>
		<script is:inline src="/resources/js/ai-features.js"></script>
		<Analytics />
		</body>
</html>
