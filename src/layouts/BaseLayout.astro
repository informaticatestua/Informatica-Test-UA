---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
	title?: string;
}

const { title = "Ing. Informática Tests UA" } = Astro.props;

const supabaseUrl     = import.meta.env.PUBLIC_SUPABASE_URL     ?? '';
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
		<title>{title}</title>
		<link rel="icon" type="image/png" href="/resources/images/logo.png" />
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;500;600&family=Outfit:wght@500;600;700;800&display=swap" rel="stylesheet">

		<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
		<link rel="stylesheet" href="/resources/css/prism.css" />
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.13.0/katex.min.css" crossorigin="anonymous" />
		<script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
		
		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();

			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
		</script>
	</head>
	<body class="min-h-screen bg-background text-text-main flex justify-center pt-[90px] pb-[40px] m-0 box-border">
		<div id="app-shell" class="w-full">
		<header class="fixed top-0 left-0 right-0 z-50 flex justify-between items-center bg-surface px-5 py-2.5 shadow-sm border-b border-border-subtle transition-colors backdrop-blur-md bg-opacity-90">
			
			<a href="https://github.com/informaticatestua/Informatica-Test-UA" class="inline-block p-2 mr-2 text-text-muted hover:text-text-main hover:bg-surface-hover rounded-full transition-colors" target="_blank" rel="noopener noreferrer">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
					<path d="M12 1.27a11 11 0 00-3.48 21.46c.55.09.73-.28.73-.55v-1.84c-3.03.64-3.67-1.46-3.67-1.46-.55-1.29-1.28-1.65-1.28-1.65-.92-.65.1-.65.1-.65 1.1 0 1.73 1.1 1.73 1.1.92 1.65 2.57 1.2 3.21.92a2 2 0 01.64-1.47c-2.47-.27-5.04-1.19-5.04-5.5 0-1.1.46-2.1 1.2-2.84a3.76 3.76 0 010-2.93s.91-.28 3.11 1.1c1.8-.49 3.7-.49 5.5 0 2.1-1.38 3.02-1.1 3.02-1.1a3.76 3.76 0 010 2.93c.83.74 1.2 1.74 1.2 2.94 0 4.21-2.57 5.13-5.04 5.4.45.37.82.92.82 2.02v3.03c0 .27.1.64.73.55A11 11 0 0012 1.27"></path>
				</svg>
			</a>

			<a href="/" class="absolute left-1/2 -translate-x-1/2 flex items-center justify-center no-underline hover:opacity-80 transition-opacity pointer-events-auto">
				<span class="title-main font-heading font-extrabold tracking-wide text-text-main">
					<span class="sm:hidden">Tests UA</span>
					<span class="hidden sm:inline whitespace-nowrap">Ing. Informática Tests UA</span>
				</span>
			</a>



			<nav aria-label="Navegación principal" class="ml-auto flex items-center gap-1">
				<!-- ─── Usuarios online (tiempo real) ────────────────────── -->
				<div id="online-counter" class="hidden flex items-center gap-1.5 px-2.5 py-1 mr-1 rounded-full text-xs font-medium text-text-muted border border-border-subtle mt-1 select-none transition-all duration-300" aria-live="polite" aria-label="Usuarios conectados ahora">
					<span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse flex-shrink-0"></span>
					<span id="online-count"><span id="online-count-num"></span><span id="online-count-suffix" class="hidden sm:inline"></span></span>
				</div>
				<!-- ─── Notificaciones (solo visible con sesión) ──────────── -->
				<div id="notif-wrapper" class="hidden relative mt-1">
					<button id="notif-btn" class="relative p-2 text-text-muted hover:text-blue-500 bg-transparent border-none rounded-full transition-colors cursor-pointer flex items-center justify-center" aria-label="Notificaciones">
						<span class="material-icons mi-md">notifications</span>
						<span id="notif-badge" class="hidden absolute top-1 right-1 min-w-[16px] h-4 px-1 bg-red-500 rounded-full border-2 border-surface flex items-center justify-center">
							<span id="notif-count" class="text-white font-bold leading-none" style="font-size:0.55rem;">0</span>
						</span>
					</button>
					<!-- Dropdown -->
					<div id="notif-dropdown" class="hidden absolute right-0 top-full mt-2 w-80 bg-surface border border-border-subtle rounded-xl shadow-lg z-[200] overflow-hidden">
						<div class="px-4 py-3 border-b border-border-subtle flex items-center justify-between">
							<span class="font-heading font-semibold text-text-main text-sm">Notificaciones</span>
							<button id="notif-mark-all-btn" class="text-xs text-blue-500 hover:text-blue-600 bg-transparent border-none cursor-pointer p-0 font-medium transition-colors">Marcar todos como leídos</button>
						</div>
						<div id="notif-list" class="max-h-72 overflow-y-auto divide-y divide-border-subtle"></div>
					</div>
				</div>
				<!-- ─── Auth: botón login (visible si no hay sesión) ───────── -->
				<a id="auth-login-btn" href="/login" class="hidden mt-1 ml-1 px-2 sm:px-3 py-1.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors no-underline flex items-center gap-1.5">
					<span class="material-icons mi-sm">login</span>
					<span class="hidden sm:inline">Entrar</span>
				</a>

				<!-- ─── Auth: avatar (visible si hay sesión) ──────────────── -->
				<div id="auth-user-btn" class="hidden relative mt-1 ml-1">
					<button id="auth-avatar-trigger" class="flex items-center justify-center w-8 h-8 rounded-full overflow-hidden border-2 border-border-subtle hover:border-blue-400 transition-colors cursor-pointer bg-surface-hover p-0" aria-label="Mi cuenta">
						<img id="auth-user-avatar" src="" alt="Avatar" class="hidden w-full h-full object-cover" />
						<span id="auth-user-initial" class="text-text-main font-bold text-sm leading-none hidden"></span>
					</button>
					<!-- Dropdown -->
					<div id="auth-dropdown" class="hidden absolute right-0 top-full mt-2 w-48 bg-surface border border-border-subtle rounded-xl shadow-lg z-[200] overflow-hidden py-1">
						<a href="/perfil" class="flex items-center gap-2 px-4 py-2.5 text-sm text-text-main hover:bg-surface-hover transition-colors no-underline">
							<span class="material-icons mi-sm text-text-muted">person</span>
							Mi perfil
						</a>
						<a id="auth-admin-link" href="/admin" class="hidden items-center gap-2 px-4 py-2.5 text-sm text-purple-600 dark:text-purple-400 hover:bg-surface-hover transition-colors no-underline">
							<span class="material-icons mi-sm">admin_panel_settings</span>
							Panel admin
						</a>
						<hr class="border-border-subtle my-1 mx-2" />
						<button id="auth-logout-btn" class="w-full flex items-center gap-2 px-4 py-2.5 text-sm text-red-500 hover:bg-surface-hover transition-colors bg-transparent border-none cursor-pointer text-left">
							<span class="material-icons mi-sm">logout</span>
							Cerrar sesión
						</button>
					</div>
				</div>
			</nav>
		</header>

		<!-- ─── AI Settings overlay ──────────────────────────────────────────── -->
		<div id="ai-settings-overlay" class="hidden fixed inset-0 z-[300] bg-black/60 backdrop-blur-sm"></div>

		<!-- ─── AI Settings modal ────────────────────────────────────────────── -->
		<div id="ai-settings-modal" class="hidden fixed inset-0 z-[301] flex items-center justify-center p-4">
			<div class="ai-settings-box w-full max-w-md bg-surface rounded-2xl shadow-2xl border border-border-subtle overflow-hidden">
				<div class="h-1 w-full bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500"></div>
				<div class="p-6">
					<div class="flex items-center justify-between mb-5">
						<div class="flex items-center gap-2">
							<span class="material-icons text-blue-500">auto_awesome</span>
							<h3 class="font-heading font-bold text-text-main text-lg m-0">Configuración de IA</h3>
						</div>
						<button id="ai-settings-close" class="p-1 text-text-muted hover:text-text-main rounded-full hover:bg-surface-hover transition-colors cursor-pointer border-none bg-transparent" aria-label="Cerrar">
							<span class="material-icons">close</span>
						</button>
					</div>

					<!-- Aviso sin clave configurada -->
					<div id="ai-settings-no-key-msg" class="hidden mb-4 p-3 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-300 dark:border-yellow-700 rounded-lg text-yellow-800 dark:text-yellow-300 text-sm">
						Configura una API Key para usar las explicaciones de IA.
					</div>

					<!-- Selección de proveedor -->
					<p class="text-text-muted text-xs font-semibold uppercase tracking-wider mb-3">Proveedor activo</p>
					<div class="grid grid-cols-3 gap-2 mb-5">
						<label class="ai-provider-card">
							<input type="radio" name="ai-provider" value="gemini" class="sr-only">
							<span class="material-icons text-blue-500" style="font-size:1.5rem;">auto_awesome</span>
							<span class="text-xs font-semibold text-text-main">Gemini</span>
						</label>
						<label class="ai-provider-card">
							<input type="radio" name="ai-provider" value="groq" class="sr-only">
							<span class="text-orange-500 font-bold leading-none" style="font-size:1.5rem;">⚡</span>
							<span class="text-xs font-semibold text-text-main">Groq</span>
						</label>
						<label class="ai-provider-card">
							<input type="radio" name="ai-provider" value="deepseek" class="sr-only">
							<span class="text-blue-400 font-bold leading-none" style="font-size:1.5rem;">🐋</span>
							<span class="text-xs font-semibold text-text-main">DeepSeek</span>
						</label>
					</div>

					<!-- Gemini config -->
					<div id="ai-gemini-config" class="space-y-3">
						<div>
							<label class="block text-sm font-medium text-text-main mb-1" for="ai-gemini-key">API Key de Google Gemini</label>
							<input id="ai-gemini-key" type="password" placeholder="AIza..." class="ai-input" autocomplete="off" />
						</div>
						<div>
							<label class="block text-sm font-medium text-text-main mb-1" for="ai-gemini-model">Modelo</label>
							<select id="ai-gemini-model" class="ai-select">
								<option value="gemini-2.0-flash">gemini-2.0-flash</option>
								<option value="gemini-2.5-flash">gemini-2.5-flash</option>
								<option value="gemini-1.5-pro">gemini-1.5-pro</option>
							</select>
						</div>
					</div>

					<!-- Groq config -->
					<div id="ai-groq-config" class="hidden space-y-3">
						<div>
							<label class="block text-sm font-medium text-text-main mb-1" for="ai-groq-key">API Key de Groq</label>
							<input id="ai-groq-key" type="password" placeholder="gsk_..." class="ai-input" autocomplete="off" />
						</div>
						<div>
							<label class="block text-sm font-medium text-text-main mb-1" for="ai-groq-model">Modelo</label>
							<select id="ai-groq-model" class="ai-select">
								<option value="llama-3.3-70b-versatile">llama-3.3-70b-versatile</option>
								<option value="deepseek-r1-distill-llama-70b">deepseek-r1-distill-llama-70b</option>
								<option value="llama-3.1-8b-instant">llama-3.1-8b-instant (rápido)</option>
							</select>
						</div>
					</div>

					<!-- DeepSeek config -->
					<div id="ai-deepseek-config" class="hidden space-y-3">
						<div>
							<label class="block text-sm font-medium text-text-main mb-1" for="ai-deepseek-key">API Key de DeepSeek</label>
							<input id="ai-deepseek-key" type="password" placeholder="sk-..." class="ai-input" autocomplete="off" />
						</div>
						<div>
							<label class="block text-sm font-medium text-text-main mb-1" for="ai-deepseek-model">Modelo</label>
							<select id="ai-deepseek-model" class="ai-select">
								<option value="deepseek-chat">deepseek-chat</option>
								<option value="deepseek-reasoner">deepseek-reasoner</option>
							</select>
						</div>
					</div>

					<div class="mt-6 flex justify-end">
						<button id="ai-settings-save" class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-semibold transition-colors cursor-pointer border-none">
							Guardar y aplicar
						</button>
					</div>
				</div>
			</div>
		</div>

		<!-- ─── AI Onboarding overlay ──────────────────────────────────────── -->
		<div id="ai-onboarding-overlay" class="hidden fixed inset-0 z-[400] bg-black/70 backdrop-blur-sm"></div>

		<!-- ─── AI Onboarding modal ────────────────────────────────────────── -->
		<div id="ai-onboarding-modal" class="hidden fixed inset-0 z-[401] flex items-center justify-center p-4">
			<div class="w-full max-w-md bg-surface rounded-2xl shadow-2xl border border-border-subtle overflow-hidden">
				<div class="h-1 w-full bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500"></div>
				<div class="p-6">

					<!-- Cabecera -->
					<div class="flex items-start justify-between mb-4">
						<div class="flex items-center gap-3">
							<div class="flex items-center justify-center w-10 h-10 rounded-xl bg-blue-100 dark:bg-blue-900/40 flex-shrink-0">
								<span class="material-icons text-blue-500">auto_awesome</span>
							</div>
							<div>
								<h3 class="font-heading font-bold text-text-main text-base m-0 leading-tight">Nueva funcionalidad: Explicaciones con IA</h3>
								<p class="text-text-muted text-xs mt-0.5 m-0">Obtén explicaciones detalladas de cada respuesta</p>
							</div>
						</div>
						<button id="ai-onboarding-close" class="p-1 text-text-muted hover:text-text-main rounded-full hover:bg-surface-hover transition-colors cursor-pointer border-none bg-transparent flex-shrink-0" aria-label="Cerrar">
							<span class="material-icons">close</span>
						</button>
					</div>

					<!-- Pasos -->
					<ol class="space-y-3 mb-6">
						<li class="flex items-start gap-3">
							<span class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-600 text-white text-xs font-bold flex items-center justify-center mt-0.5">1</span>
							<div>
								<p class="text-text-main text-sm font-medium m-0">Abre la configuración de IA</p>
								<p class="text-text-muted text-xs mt-0.5 m-0">Pulsa el icono <span class="material-icons align-middle text-blue-500" style="font-size:0.95rem;">auto_awesome</span> en la barra superior.</p>
							</div>
						</li>
						<li class="flex items-start gap-3">
							<span class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-600 text-white text-xs font-bold flex items-center justify-center mt-0.5">2</span>
							<div>
								<p class="text-text-main text-sm font-medium m-0">Elige un proveedor</p>
								<p class="text-text-muted text-xs mt-0.5 m-0">Selecciona <strong>Gemini</strong>, <strong>Groq</strong> o <strong>DeepSeek</strong>. Los tres ofrecen planes gratuitos.</p>
							</div>
						</li>
						<li class="flex items-start gap-3">
							<span class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-600 text-white text-xs font-bold flex items-center justify-center mt-0.5">3</span>
							<div>
								<p class="text-text-main text-sm font-medium m-0">Obtén una API Key gratuita</p>
								<p class="text-text-muted text-xs mt-0.5 m-0">Regístrate en la web del proveedor y genera una clave. Pégala en el campo correspondiente.</p>
							</div>
						</li>
						<li class="flex items-start gap-3">
							<span class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-600 text-white text-xs font-bold flex items-center justify-center mt-0.5">4</span>
							<div>
								<p class="text-text-main text-sm font-medium m-0">Guarda y aplica</p>
								<p class="text-text-muted text-xs mt-0.5 m-0">Haz clic en <strong>Guardar y aplicar</strong>. La configuración se guarda en tu navegador.</p>
							</div>
						</li>
						<li class="flex items-start gap-3">
							<span class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-600 text-white text-xs font-bold flex items-center justify-center mt-0.5">5</span>
							<div>
								<p class="text-text-main text-sm font-medium m-0">¡Úsala al responder!</p>
								<p class="text-text-muted text-xs mt-0.5 m-0">Tras contestar una pregunta, pulsa el botón <strong>Explicar con IA</strong> para recibir una explicación detallada.</p>
							</div>
						</li>
					</ol>

					<!-- Pie -->
					<div class="flex items-center justify-between gap-3">
						<label class="flex items-center gap-2 cursor-pointer select-none">
							<input id="ai-onboarding-no-show" type="checkbox" class="w-4 h-4 accent-blue-600 rounded cursor-pointer" />
							<span class="text-text-muted text-xs">No volver a mostrar</span>
						</label>
						<button id="ai-onboarding-ok" class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-semibold transition-colors cursor-pointer border-none">
							¡Entendido!
						</button>
					</div>
				</div>
			</div>
		</div>

		<!-- ─── Credenciales Supabase (anon key pública, seguro exponer) ── -->
		<script is:inline define:vars={{ supabaseUrl, supabaseAnonKey }}>
			window.SUPABASE_URL      = supabaseUrl;
			window.SUPABASE_ANON_KEY = supabaseAnonKey;
		</script>
		<!-- ─── Supabase JS SDK (UMD, expone window.supabase) ─────────── -->
		<script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js"></script>
		<script is:inline src="/resources/js/supabase-client.js"></script>
		<script is:inline src="/resources/js/online-users.js"></script>
		<script is:inline src="/resources/js/utils.js"></script>
		<script is:inline src="/resources/js/auth.js"></script>
		<script is:inline src="/resources/js/quiz-data.js"></script>

		<main class="w-full">
			<slot />
		</main>
		</div>

		
		<script is:inline>
			(function () {
				const LS_KEY = "ai_onboarding_seen_v1";
				const $ = (id) => document.getElementById(id);

				function close(persist) {
					$("ai-onboarding-modal")?.classList.add("hidden");
					$("ai-onboarding-overlay")?.classList.add("hidden");
					document.body.classList.remove("overflow-hidden");
					if (persist) localStorage.setItem(LS_KEY, "1");
				}

				function init() {
					if (localStorage.getItem(LS_KEY)) return;
					$("ai-onboarding-modal")?.classList.remove("hidden");
					$("ai-onboarding-overlay")?.classList.remove("hidden");
					document.body.classList.add("overflow-hidden");

					$("ai-onboarding-ok")?.addEventListener("click", function () {
						const noShow = $("ai-onboarding-no-show")?.checked;
						close(noShow);
					});
					$("ai-onboarding-close")?.addEventListener("click", function () {
						close(false);
					});
					$("ai-onboarding-overlay")?.addEventListener("click", function () {
						close(false);
					});
					document.addEventListener("keydown", function (e) {
						if (e.key === "Escape" && !$("ai-onboarding-modal")?.classList.contains("hidden")) {
							close(false);
						}
					});
				}

				if (document.readyState === "loading") {
					document.addEventListener("DOMContentLoaded", init);
				} else {
					init();
				}
			})();
		</script>

		<!-- ─── Auth dropdown ───────────────────────────────────────────────── -->
		<script is:inline>
		(function () {
			"use strict";
			function initAuthDropdown() {
				const trigger  = document.getElementById("auth-avatar-trigger");
				const dropdown = document.getElementById("auth-dropdown");
				const logoutBtn = document.getElementById("auth-logout-btn");

				if (!trigger || !dropdown) return;

				trigger.addEventListener("click", function (e) {
					e.stopPropagation();
					dropdown.classList.toggle("hidden");
				});

				document.addEventListener("click", function () {
					dropdown.classList.add("hidden");
				});

				logoutBtn?.addEventListener("click", function () {
					window.Auth?.logout();
				});
			}

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", initAuthDropdown);
			} else {
				initAuthDropdown();
			}
		})();
		</script>

		<script is:inline src="/resources/js/notifications.js"></script>
		<script is:inline src="/resources/js/ai-features.js"></script>
		<Analytics />
		</body>
</html>
