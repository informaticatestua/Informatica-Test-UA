---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contribuir pregunta • Tests UA">

<!-- Loading -->
<div id="contrib-loading" class="flex flex-col items-center justify-center min-h-[60vh] gap-4">
	<div class="w-8 h-8 border-2 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
	<p class="text-text-muted text-sm">Cargando…</p>
</div>

<div id="contrib-content" class="hidden max-w-2xl mx-auto px-4 sm:px-6 py-8 space-y-5 w-full">

	<!-- ── Header ─────────────────────────────────────────────────────────── -->
	<div class="flex items-center gap-3">
		<a href="/" class="p-1.5 text-text-muted hover:text-text-main hover:bg-surface-hover rounded-lg transition-colors no-underline">
			<span class="material-icons" style="font-size:1.3rem;">arrow_back</span>
		</a>
		<div>
			<h1 class="font-heading font-bold text-text-main text-xl m-0">Contribuir una pregunta</h1>
			<p class="text-text-muted text-sm m-0 mt-0.5">El equipo la revisará antes de publicarla</p>
		</div>
	</div>

	<!-- ── Formulario ─────────────────────────────────────────────────────── -->
	<div id="contrib-form" class="bg-surface border border-border-subtle rounded-2xl p-6 space-y-5">

		<div id="contrib-error" class="hidden p-3 bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 rounded-lg text-red-700 dark:text-red-400 text-sm"></div>

		<!-- Asignatura -->
		<div>
			<label class="block text-sm font-medium text-text-main mb-1.5" for="contrib-subject">Asignatura <span class="text-red-500">*</span></label>
			<select id="contrib-subject" class="w-full px-3 py-2.5 rounded-lg bg-background border border-border-subtle text-text-main text-sm focus:outline-none focus:border-blue-500 transition-colors">
				<option value="">Selecciona una asignatura…</option>
			</select>
		</div>

		<!-- Enunciado -->
		<div>
			<label class="block text-sm font-medium text-text-main mb-1.5" for="contrib-body">Enunciado <span class="text-red-500">*</span></label>
			<textarea id="contrib-body" rows="4" placeholder="Escribe el enunciado de la pregunta… (admite `código` y $$LaTeX$$)" class="w-full px-3 py-2.5 rounded-lg bg-background border border-border-subtle text-text-main text-sm focus:outline-none focus:border-blue-500 transition-colors resize-y"></textarea>
		</div>

		<!-- Opciones -->
		<div>
			<div class="flex items-center justify-between mb-1.5">
				<label class="block text-sm font-medium text-text-main">Opciones de respuesta <span class="text-red-500">*</span></label>
				<span class="text-xs text-text-muted">Marca la correcta</span>
			</div>
			<div id="contrib-options" class="space-y-2">
				<!-- filas generadas por JS -->
			</div>
			<p class="text-xs text-text-muted mt-2">Mínimo 2 opciones rellenas, máximo 4. Solo una correcta.</p>
		</div>

		<div class="flex justify-end pt-1">
			<button id="contrib-submit" class="flex items-center gap-2 px-6 py-2.5 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-xl transition-colors cursor-pointer border-none disabled:opacity-50 disabled:cursor-not-allowed">
				<span class="material-icons text-[16px]">send</span>
				Enviar pregunta
			</button>
		</div>
	</div>

	<!-- ── Éxito ──────────────────────────────────────────────────────────── -->
	<div id="contrib-success" class="hidden bg-surface border border-border-subtle rounded-2xl p-8 flex flex-col items-center gap-3 text-center">
		<div class="w-14 h-14 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
			<span class="material-icons text-green-600 dark:text-green-400" style="font-size:1.8rem;">check_circle</span>
		</div>
		<p class="font-heading font-bold text-text-main text-lg m-0">Pregunta enviada</p>
		<p class="text-text-muted text-sm m-0">El equipo la revisará próximamente. Puedes seguir su estado desde tu perfil.</p>
		<div class="flex flex-wrap justify-center gap-2 mt-2">
			<a href="/perfil" class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors no-underline">Ver mis contribuciones</a>
			<button id="contrib-another" class="px-4 py-2 text-sm font-medium text-text-muted hover:text-text-main bg-transparent hover:bg-surface-hover border border-border-subtle rounded-lg transition-colors cursor-pointer">Enviar otra</button>
		</div>
	</div>

</div>

<script is:inline>
(function () {
    "use strict";

    const MAX_OPTIONS = 4;

    function getDb() { return window.SupabaseClient; }
    const $ = (id) => document.getElementById(id);

    // ── Opciones dinámicas ────────────────────────────────────────────────────

    function renderOptionRows() {
        const box = $("contrib-options");
        if (!box) return;
        box.innerHTML = "";
        for (let i = 0; i < MAX_OPTIONS; i++) {
            const row = document.createElement("div");
            row.className = "flex items-center gap-2.5";
            row.innerHTML = `
                <input type="radio" name="contrib-correct" class="contrib-correct flex-shrink-0 w-[18px] h-[18px] accent-green-600 cursor-pointer" title="Marcar como correcta" aria-label="Opción ${i + 1} correcta" />
                <input type="text" class="contrib-option-text flex-1 px-3 py-2.5 rounded-lg bg-background border border-border-subtle text-text-main text-sm focus:outline-none focus:border-blue-500 transition-colors" placeholder="Opción ${i + 1}${i < 2 ? "" : " (opcional)"}" autocomplete="off" />
            `;
            box.appendChild(row);
        }
    }

    function readOptions() {
        const rows = Array.from(document.querySelectorAll("#contrib-options > div"));
        return rows
            .map((row, i) => ({
                content: row.querySelector(".contrib-option-text")?.value?.trim() || "",
                is_correct: row.querySelector(".contrib-correct")?.checked || false,
                position: i + 1,
            }))
            .filter((o) => o.content.length > 0);
    }

    // ── Asignaturas ───────────────────────────────────────────────────────────

    async function loadSubjects() {
        const db = getDb();
        if (!db) return;

        const { data } = await db
            .from("subjects")
            .select("id, display_name, parent_id, sort_order")
            .order("sort_order", { ascending: true });

        const subjects = data || [];
        const parentIds = new Set(subjects.map((s) => s.parent_id).filter(Boolean));
        const leaves = subjects.filter((s) => !parentIds.has(s.id));
        const parentName = (pid) => subjects.find((s) => s.id === pid)?.display_name || pid;

        const select = $("contrib-subject");
        if (!select) return;

        // Agrupar hojas por padre para legibilidad
        const groups = new Map();
        for (const s of leaves) {
            const key = s.parent_id ? parentName(s.parent_id) : "";
            if (!groups.has(key)) groups.set(key, []);
            groups.get(key).push(s);
        }

        for (const [groupName, items] of groups) {
            const target = groupName ? document.createElement("optgroup") : select;
            if (groupName) target.label = groupName;
            for (const s of items) {
                const opt = document.createElement("option");
                opt.value = s.id;
                opt.textContent = s.display_name;
                target.appendChild(opt);
            }
            if (groupName) select.appendChild(target);
        }

        // Preselección por query param (?subject=slug)
        const pre = new URLSearchParams(window.location.search).get("subject");
        if (pre && select.querySelector(`option[value="${CSS.escape(pre)}"]`)) {
            select.value = pre;
        }
    }

    // ── Validación + envío ────────────────────────────────────────────────────

    function showError(msg) {
        const el = $("contrib-error");
        if (el) { el.textContent = msg; el.classList.remove("hidden"); el.scrollIntoView({ behavior: "smooth", block: "center" }); }
    }

    function validate() {
        const subject = $("contrib-subject")?.value;
        const body    = $("contrib-body")?.value?.trim();
        const options = readOptions();

        if (!subject) return "Selecciona la asignatura.";
        if (!body || body.length < 10) return "El enunciado debe tener al menos 10 caracteres.";
        if (options.length < 2) return "Rellena al menos 2 opciones de respuesta.";
        if (!options.some((o) => o.is_correct)) return "Marca cuál es la opción correcta.";
        return null;
    }

    async function submit() {
        const err = validate();
        if (err) { showError(err); return; }
        $("contrib-error")?.classList.add("hidden");

        const db   = getDb();
        const user = window.Auth?.getUser();
        if (!db || !user) return;

        const btn = $("contrib-submit");
        btn.disabled = true;
        btn.innerHTML = `<div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div> Enviando…`;

        const { data: contribution, error } = await db
            .from("contributions")
            .insert({
                user_id:    user.id,
                subject_id: $("contrib-subject").value,
                content:    $("contrib-body").value.trim(),
            })
            .select("id")
            .single();

        let optsError = null;
        if (!error && contribution) {
            const rows = readOptions().map((o) => ({ ...o, contribution_id: contribution.id }));
            ({ error: optsError } = await db.from("contribution_options").insert(rows));
        }

        btn.disabled = false;
        btn.innerHTML = `<span class="material-icons text-[16px]">send</span> Enviar pregunta`;

        if (error || optsError) {
            console.error("[Contribuir] error:", error || optsError);
            showError("No se pudo enviar la pregunta. Inténtalo de nuevo.");
            return;
        }

        $("contrib-form")?.classList.add("hidden");
        $("contrib-success")?.classList.remove("hidden");
        window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function resetForm() {
        $("contrib-body").value = "";
        renderOptionRows();
        $("contrib-success")?.classList.add("hidden");
        $("contrib-form")?.classList.remove("hidden");
    }

    // ── Main ─────────────────────────────────────────────────────────────────

    async function main() {
        const { user } = await new Promise((resolve) =>
            window.Auth?.onReady((u, p) => resolve({ user: u, profile: p }))
        );

        if (!user) {
            window.location.replace("/login?redirect=" + encodeURIComponent(window.location.pathname + window.location.search));
            return;
        }

        renderOptionRows();
        await loadSubjects();

        $("contrib-loading")?.classList.add("hidden");
        $("contrib-content")?.classList.remove("hidden");

        $("contrib-submit")?.addEventListener("click", submit);
        $("contrib-another")?.addEventListener("click", resetForm);
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", main);
    } else {
        main();
    }
})();
</script>
</BaseLayout>
