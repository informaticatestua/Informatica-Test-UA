---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Iniciar sesión — Ing. Informática Tests UA">

<div class="flex items-center justify-center min-h-[calc(100vh-90px)] w-full px-4">
    <div class="w-full max-w-sm bg-surface border border-border-subtle rounded-2xl shadow-md p-8 flex flex-col items-center gap-6">

        <div class="flex flex-col items-center gap-2 text-center">
            <span class="material-icons text-blue-500" style="font-size:2.5rem;">school</span>
            <h1 class="font-heading font-bold text-text-main text-2xl m-0">Bienvenido</h1>
            <p class="text-text-muted text-sm m-0">Inicia sesión para acceder a todas las funcionalidades</p>
        </div>

        <ul class="w-full space-y-2 text-sm text-text-muted list-none p-0 m-0">
            <li class="flex items-center gap-2"><span class="material-icons text-blue-500" style="font-size:1.1rem;">check</span>Guarda tus preguntas falladas</li>
            <li class="flex items-center gap-2"><span class="material-icons text-blue-500" style="font-size:1.1rem;">check</span>Reporta errores en las preguntas</li>
            <li class="flex items-center gap-2"><span class="material-icons text-blue-500" style="font-size:1.1rem;">check</span>Contribuye con nuevas preguntas</li>
            <li class="flex items-center gap-2"><span class="material-icons text-blue-500" style="font-size:1.1rem;">check</span>Retoma los tests donde los dejaste</li>
        </ul>

        <button id="google-login-btn" class="w-full flex items-center justify-center gap-3 px-5 py-3 bg-white dark:bg-surface-hover border border-border-subtle rounded-xl text-text-main font-semibold text-sm shadow-sm hover:shadow transition-all cursor-pointer hover:bg-gray-50 dark:hover:bg-surface-hover/80 active:scale-[0.98]">
            <svg width="20" height="20" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M44.5 20H24v8.5h11.8C34.7 33.9 30.1 37 24 37c-7.2 0-13-5.8-13-13s5.8-13 13-13c3.1 0 5.9 1.1 8.1 2.9l6.4-6.4C34.6 4.1 29.6 2 24 2 11.8 2 2 11.8 2 24s9.8 22 22 22c11 0 21-8 21-22 0-1.3-.2-2.7-.5-4z" fill="#FFC107"/>
                <path d="M6.3 14.7l7 5.1C15.1 15.9 19.2 13 24 13c3.1 0 5.9 1.1 8.1 2.9l6.4-6.4C34.6 4.1 29.6 2 24 2 16.3 2 9.6 7.3 6.3 14.7z" fill="#FF3D00"/>
                <path d="M24 46c5.5 0 10.5-1.9 14.3-5.1l-6.6-5.6C29.5 36.9 26.9 38 24 38c-6.1 0-11.2-4.1-13.1-9.6L3.7 34c3.2 7.5 10.1 12 20.3 12z" fill="#4CAF50"/>
                <path d="M44.5 20H24v8.5h11.8c-1 3-3.2 5.4-6.3 7.1l6.6 5.6C40.5 38.1 45 32.1 45 24c0-1.3-.2-2.7-.5-4z" fill="#1976D2"/>
            </svg>
            Continuar con Google
        </button>

        <p id="login-error" class="hidden text-red-500 text-xs text-center m-0"></p>

        <p class="text-text-muted text-xs text-center m-0">
            Al iniciar sesión aceptas nuestras <a href="/privacidad" class="underline hover:text-text-main transition-colors">condiciones de uso y política de privacidad</a>.
        </p>
    </div>
</div>

<script is:inline>
(function () {
    "use strict";

    function init() {
        // Si ya hay sesión, redirigir al inicio
        window.Auth?.onReady(function (user) {
            if (user) window.location.replace("/");
        });

        const btn = document.getElementById("google-login-btn");
        const errEl = document.getElementById("login-error");

        btn?.addEventListener("click", async function () {
            btn.disabled = true;
            btn.textContent = "Redirigiendo…";
            try {
                await window.Auth.loginWithGoogle();
            } catch (e) {
                if (errEl) {
                    errEl.textContent = "Error al iniciar sesión. Inténtalo de nuevo.";
                    errEl.classList.remove("hidden");
                }
                btn.disabled = false;
                btn.innerHTML = `
                    <svg width="20" height="20" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M44.5 20H24v8.5h11.8C34.7 33.9 30.1 37 24 37c-7.2 0-13-5.8-13-13s5.8-13 13-13c3.1 0 5.9 1.1 8.1 2.9l6.4-6.4C34.6 4.1 29.6 2 24 2 11.8 2 2 11.8 2 24s9.8 22 22 22c11 0 21-8 21-22 0-1.3-.2-2.7-.5-4z" fill="#FFC107"/>
                        <path d="M6.3 14.7l7 5.1C15.1 15.9 19.2 13 24 13c3.1 0 5.9 1.1 8.1 2.9l6.4-6.4C34.6 4.1 29.6 2 24 2 16.3 2 9.6 7.3 6.3 14.7z" fill="#FF3D00"/>
                        <path d="M24 46c5.5 0 10.5-1.9 14.3-5.1l-6.6-5.6C29.5 36.9 26.9 38 24 38c-6.1 0-11.2-4.1-13.1-9.6L3.7 34c3.2 7.5 10.1 12 20.3 12z" fill="#4CAF50"/>
                        <path d="M44.5 20H24v8.5h11.8c-1 3-3.2 5.4-6.3 7.1l6.6 5.6C40.5 38.1 45 32.1 45 24c0-1.3-.2-2.7-.5-4z" fill="#1976D2"/>
                    </svg>
                    Continuar con Google`;
            }
        });
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init);
    } else {
        init();
    }
})();
</script>

</BaseLayout>
