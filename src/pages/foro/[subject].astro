---
import BaseLayout from '../../layouts/BaseLayout.astro';

const { subject } = Astro.params;
const subjectTitle = subject ? subject.toUpperCase() : 'Foro';
---

<BaseLayout title={`Foro ${subjectTitle} • Tests UA`}>

<!-- Loading -->
<div id="foro-loading" class="flex flex-col items-center justify-center min-h-[60vh] gap-4">
	<div class="w-8 h-8 border-2 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
	<p class="text-text-muted text-sm">Cargando foro…</p>
</div>

<div id="foro-content" class="hidden max-w-3xl mx-auto px-4 sm:px-6 py-6 w-full space-y-5">

	<!-- Header -->
	<div class="flex items-center justify-between gap-3 flex-wrap">
		<div class="flex items-center gap-3">
			<a href={`/${subject}`} class="p-1.5 text-text-muted hover:text-text-main hover:bg-surface-hover rounded-lg transition-colors no-underline">
				<span class="material-icons" style="font-size:1.3rem;">arrow_back</span>
			</a>
			<div>
				<h1 class="font-heading font-bold text-text-main text-xl m-0 flex items-center gap-2">
					<span class="material-icons text-blue-500">forum</span>
					Foro — <span id="foro-subject-name" class="text-blue-600 dark:text-blue-400">{subjectTitle}</span>
				</h1>
				<p class="text-text-muted text-sm m-0 mt-0.5">Debate y preguntas sobre esta asignatura</p>
			</div>
		</div>
		<button id="new-thread-btn" class="flex items-center gap-1.5 px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors border-none cursor-pointer">
			<span class="material-icons text-[16px]">add</span>
			Nuevo hilo
		</button>
	</div>

	<!-- Threads list -->
	<div id="threads-loading" class="flex items-center gap-3 py-10 text-text-muted">
		<div class="w-5 h-5 border-2 border-blue-500 border-t-transparent rounded-full animate-spin flex-shrink-0"></div>
		<span class="text-sm">Cargando hilos…</span>
	</div>
	<div id="threads-empty" class="hidden flex flex-col items-center justify-center py-20 gap-3 text-center">
		<div class="w-16 h-16 rounded-2xl bg-surface-hover border border-border-subtle flex items-center justify-center">
			<span class="material-icons text-text-muted" style="font-size:2rem;">forum</span>
		</div>
		<p class="text-text-main font-medium m-0">Nadie ha abierto un hilo todavía</p>
		<p class="text-text-muted text-sm m-0">¡Sé el primero en iniciar un debate!</p>
	</div>
	<div id="threads-list" class="hidden space-y-3"></div>
</div>

<!-- Modal: Nuevo hilo -->
<div id="new-thread-overlay" class="hidden fixed inset-0 z-[300] bg-black/60 backdrop-blur-sm"></div>
<div id="new-thread-modal" class="hidden fixed inset-0 z-[301] flex items-center justify-center p-4">
	<div class="new-thread-box w-full max-w-lg bg-surface rounded-2xl shadow-2xl border border-border-subtle overflow-hidden">
		<div class="h-1 w-full bg-gradient-to-r from-blue-500 via-indigo-500 to-purple-500"></div>
		<div class="p-5 sm:p-6 space-y-4">
			<div class="flex items-center justify-between">
				<h3 class="font-heading font-bold text-text-main text-lg m-0">Nuevo hilo</h3>
				<button id="new-thread-close" class="p-1 text-text-muted hover:text-text-main rounded-full hover:bg-surface-hover transition-colors cursor-pointer border-none bg-transparent">
					<span class="material-icons">close</span>
				</button>
			</div>

			<div id="new-thread-error" class="hidden p-3 bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 rounded-lg text-red-700 dark:text-red-400 text-sm"></div>

			<div id="new-thread-login-msg" class="hidden p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-300 dark:border-blue-700 rounded-lg text-blue-700 dark:text-blue-300 text-sm text-center">
				<span class="material-icons align-middle mr-1" style="font-size:1rem;">lock</span>
				Debes <a href="/login" class="font-semibold underline">iniciar sesión</a> para crear un hilo.
			</div>

			<div id="new-thread-form" class="space-y-4">
				<div>
					<label class="block text-sm font-medium text-text-main mb-1.5" for="thread-title">Título <span class="text-red-500">*</span></label>
					<input id="thread-title" type="text" maxlength="150" placeholder="Resumen breve del tema que quieres tratar…"
						class="w-full px-3 py-2.5 rounded-lg bg-background border border-border-subtle text-text-main text-sm focus:outline-none focus:border-blue-500 transition-colors" autocomplete="off" />
				</div>
				<div>
					<label class="block text-sm font-medium text-text-main mb-1.5" for="thread-body">Mensaje <span class="text-red-500">*</span></label>
					<textarea id="thread-body" rows="5" placeholder="Desarrolla tu pregunta o debate aquí…"
						class="w-full px-3 py-2.5 rounded-lg bg-background border border-border-subtle text-text-main text-sm focus:outline-none focus:border-blue-500 transition-colors resize-y"></textarea>
				</div>
				<div class="flex justify-end gap-3 pt-1">
					<button id="new-thread-cancel" class="px-4 py-2 text-sm font-medium text-text-muted hover:text-text-main bg-transparent hover:bg-surface-hover border border-border-subtle rounded-lg transition-colors cursor-pointer">Cancelar</button>
					<button id="new-thread-submit" class="flex items-center gap-2 px-5 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors cursor-pointer border-none disabled:opacity-50 disabled:cursor-not-allowed">
						<span class="material-icons text-[15px]">send</span>
						Publicar hilo
					</button>
				</div>
			</div>
		</div>
	</div>
</div>

<script is:inline define:vars={{ subject }}>
(function () {
    "use strict";

    // Grupos multi-archivo → subject real en BD (mismo mapa que quiz-data.js)
    const GROUP_PARENT_MAP = { sdsfull: "sds", redes_full: "redes_parent" };

    let SUBJECT_ID = subject;

    function getDb() { return window.SupabaseClient; }

    function esc(str) {
        return String(str ?? "")
            .replace(/&/g, "&amp;").replace(/</g, "&lt;")
            .replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }

    function formatTimeAgo(iso) {
        const diff = (Date.now() - new Date(iso).getTime()) / 1000;
        if (diff < 60) return "Ahora";
        if (diff < 3600) return `Hace ${Math.floor(diff / 60)} min`;
        if (diff < 86400) return `Hace ${Math.floor(diff / 3600)} h`;
        if (diff < 604800) return `Hace ${Math.floor(diff / 86400)} d`;
        return new Date(iso).toLocaleDateString("es-ES", { day: "2-digit", month: "short", year: "numeric" });
    }

    // ── Resolución del subject (slug directo o grupo mapeado) ────────────────

    async function resolveSubject() {
        const db = getDb();
        if (!db) return null;
        const candidates = [subject, GROUP_PARENT_MAP[subject]].filter(Boolean);
        for (const id of candidates) {
            const { data } = await db.from("subjects").select("id, display_name").eq("id", id).maybeSingle();
            if (data) return data;
        }
        return null;
    }

    // ── Load threads ─────────────────────────────────────────────────────────

    async function loadThreads() {
        const db = getDb();
        if (!db) return [];
        const { data, error } = await db
            .from("forum_threads")
            .select("id, title, user_id, is_pinned, is_locked, reply_count, created_at, updated_at")
            .eq("subject_id", SUBJECT_ID)
            .order("is_pinned", { ascending: false })
            .order("updated_at", { ascending: false })
            .limit(100);
        if (error) { console.error("[Foro]", error.message); return []; }
        return data || [];
    }

    /** Nombres y avatares vía la vista public_profiles (no expone nada más). */
    async function loadAuthors(userIds) {
        const db = getDb();
        const ids = [...new Set(userIds)].filter(Boolean);
        if (!db || ids.length === 0) return {};
        const { data } = await db.from("public_profiles").select("id, username, avatar_url").in("id", ids);
        const map = {};
        (data || []).forEach(p => { map[p.id] = p; });
        return map;
    }

    function renderThreads(threads, authors) {
        document.getElementById("threads-loading")?.classList.add("hidden");
        const list = document.getElementById("threads-list");
        const empty = document.getElementById("threads-empty");
        if (!list) return;

        if (threads.length === 0) { empty?.classList.remove("hidden"); return; }

        list.classList.remove("hidden");
        list.innerHTML = threads.map(t => {
            const prof = authors[t.user_id] || null;
            const avatar = prof?.avatar_url;
            const username = esc(prof?.username || "Anónimo");
            const avatarHtml = avatar
                ? `<img src="${esc(avatar)}" alt="" referrerpolicy="no-referrer" class="w-8 h-8 rounded-full object-cover border border-border-subtle flex-shrink-0" />`
                : `<div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/40 flex items-center justify-center flex-shrink-0 text-blue-600 dark:text-blue-300 font-bold text-sm">${username[0].toUpperCase()}</div>`;

            const badges = [
                t.is_pinned ? `<span class="inline-flex items-center gap-0.5 px-1.5 py-0.5 bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300 rounded-full text-[0.65rem] font-semibold"><span class="material-icons" style="font-size:0.75rem;">push_pin</span>Fijado</span>` : "",
                t.is_locked ? `<span class="inline-flex items-center gap-0.5 px-1.5 py-0.5 bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400 rounded-full text-[0.65rem] font-semibold"><span class="material-icons" style="font-size:0.75rem;">lock</span>Cerrado</span>` : "",
            ].filter(Boolean).join("");

            return `
                <a href="/foro/hilo/${t.id}" class="block bg-surface border border-border-subtle rounded-xl p-4 hover:border-blue-400/60 hover:shadow-sm transition-all no-underline group">
                    <div class="flex items-start gap-3">
                        ${avatarHtml}
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 flex-wrap mb-1">
                                ${badges}
                                <h2 class="font-heading font-semibold text-text-main text-sm m-0 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-snug truncate">${esc(t.title)}</h2>
                            </div>
                            <div class="flex items-center gap-3 text-xs text-text-muted flex-wrap">
                                <span class="font-medium text-text-muted">@${username}</span>
                                <span>·</span>
                                <span>${formatTimeAgo(t.updated_at || t.created_at)}</span>
                                <span>·</span>
                                <span class="flex items-center gap-0.5">
                                    <span class="material-icons" style="font-size:0.85rem;">chat_bubble_outline</span>
                                    ${t.reply_count ?? 0} respuestas
                                </span>
                            </div>
                        </div>
                    </div>
                </a>
            `;
        }).join("");
    }

    // ── New thread modal ──────────────────────────────────────────────────────

    function openModal() {
        document.getElementById("new-thread-overlay")?.classList.remove("hidden");
        document.getElementById("new-thread-modal")?.classList.remove("hidden");
        document.body.classList.add("overflow-hidden");

        const user = window.Auth?.getUser();
        if (!user) {
            document.getElementById("new-thread-form")?.classList.add("hidden");
            document.getElementById("new-thread-login-msg")?.classList.remove("hidden");
        } else {
            document.getElementById("new-thread-form")?.classList.remove("hidden");
            document.getElementById("new-thread-login-msg")?.classList.add("hidden");
        }
    }

    function closeModal() {
        document.getElementById("new-thread-overlay")?.classList.add("hidden");
        document.getElementById("new-thread-modal")?.classList.add("hidden");
        document.body.classList.remove("overflow-hidden");
        document.getElementById("new-thread-error")?.classList.add("hidden");
        document.getElementById("thread-title").value = "";
        document.getElementById("thread-body").value = "";
    }

    function showError(msg) {
        const el = document.getElementById("new-thread-error");
        if (el) { el.textContent = msg; el.classList.remove("hidden"); }
    }

    async function submitThread() {
        const title = document.getElementById("thread-title")?.value.trim();
        const body = document.getElementById("thread-body")?.value.trim();

        if (!title || title.length < 4) { showError("El título debe tener al menos 4 caracteres."); return; }
        if (!body || body.length < 4) { showError("El mensaje debe tener al menos 4 caracteres."); return; }

        const db = getDb();
        if (!db) return;

        const btn = document.getElementById("new-thread-submit");
        btn.disabled = true;
        btn.innerHTML = `<div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div> Publicando…`;

        const { data: threadId, error } = await db.rpc("create_forum_thread", {
            p_subject_id: SUBJECT_ID,
            p_title: title,
            p_content: body,
        });

        btn.disabled = false;
        btn.innerHTML = `<span class="material-icons text-[15px]">send</span> Publicar hilo`;

        if (error) { showError(error.message || "Error al publicar el hilo."); return; }

        closeModal();
        window.location.href = `/foro/hilo/${threadId}`;
    }

    // ── Init ─────────────────────────────────────────────────────────────────

    function init() {
        document.getElementById("new-thread-btn")?.addEventListener("click", openModal);
        document.getElementById("new-thread-close")?.addEventListener("click", closeModal);
        document.getElementById("new-thread-cancel")?.addEventListener("click", closeModal);
        document.getElementById("new-thread-overlay")?.addEventListener("click", closeModal);
        document.getElementById("new-thread-submit")?.addEventListener("click", submitThread);

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape") closeModal();
        });
    }

    async function main() {
        await new Promise(resolve => window.Auth?.onReady(resolve));

        const resolved = await resolveSubject();
        document.getElementById("foro-loading")?.classList.add("hidden");
        document.getElementById("foro-content")?.classList.remove("hidden");

        if (!resolved) {
            document.getElementById("threads-loading")?.classList.add("hidden");
            const empty = document.getElementById("threads-empty");
            empty?.classList.remove("hidden");
            const msg = empty?.querySelector("p");
            if (msg) msg.textContent = "Asignatura no encontrada.";
            document.getElementById("new-thread-btn")?.classList.add("hidden");
            return;
        }
        SUBJECT_ID = resolved.id;

        const nameEl = document.getElementById("foro-subject-name");
        if (nameEl && resolved.display_name) {
            nameEl.textContent = resolved.display_name;
            document.title = `Foro ${resolved.display_name} • Tests UA`;
        }

        init();
        const threads = await loadThreads();
        const authors = await loadAuthors(threads.map(t => t.user_id));
        renderThreads(threads, authors);
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", main);
    } else {
        main();
    }
})();
</script>

<style>
    @reference "../../styles/global.css";

    .new-thread-box {
        opacity: 0;
        transform: translateY(16px) scale(0.97);
        transition: opacity 0.22s ease, transform 0.22s ease;
    }
    #new-thread-modal:not(.hidden) .new-thread-box {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
</style>

</BaseLayout>
