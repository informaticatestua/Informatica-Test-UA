		@apply px-[1.2em] py-[0.6em] text-[1em] border-none text-text-muted hover:text-text-main rounded-[5px] cursor-pointer whitespace-nowrap bg-transparent hover:bg-surface-hover transition-colors font-medium;
	}
	.btn-ghost {
		@apply px-[1em] py-[0.5em] text-[0.9em] border-none text-text-muted hover:text-text-main rounded-[5px] cursor-pointer whitespace-nowrap bg-transparent hover:bg-surface-hover transition-colors font-medium;
	}

	/* ── Barra de acciones del quiz ─────────────────────────────────── */
	.quiz-actions {
		@apply flex flex-col gap-3 mt-6 w-full pt-5 border-t border-border-subtle;
	}
	.quiz-actions-primary {
		@apply grid gap-2 w-full;
		grid-template-columns: minmax(0, 1fr) minmax(0, 3fr) minmax(0, 1fr);
		align-items: stretch;
	}
	.quiz-nav-btn {
		@apply inline-flex items-center justify-center gap-0.5 px-2 py-2.5 text-sm font-medium
			   text-text-muted hover:text-text-main rounded-lg border border-border-subtle
			   bg-surface hover:bg-surface-hover transition-colors cursor-pointer min-h-[48px];
	}
	.quiz-nav-btn .material-icons {
		font-size: 1.25rem;
	}
	.quiz-nav-btn-label {
		@apply hidden sm:inline;
	}
	.quiz-verify-btn {
		@apply px-4 py-2.5 text-[1em] border-none text-white rounded-lg cursor-pointer
			   bg-blue-600 hover:bg-blue-700 transition-colors shadow-sm font-semibold
			   min-h-[48px] disabled:opacity-50 disabled:cursor-not-allowed
			   disabled:hover:bg-blue-600;
	}

	#tools-quiz-section:not(:has(.tools-sheet-item[style*="flex"])) {
		display: none;
	}

	@media (min-width: 640px) {
		.quiz-actions-primary {
			@apply flex justify-center items-center;
		}
		.quiz-verify-btn {
			@apply min-w-[260px];
		}
	}

	@media (max-width: 767px) {
		.quiz-actions {
			@apply sticky bottom-0 z-30 -mx-[15px] -mb-[15px] px-[15px] py-3 mt-5
				   bg-surface/95 backdrop-blur-md border-t border-border-subtle shadow-[0_-4px_24px_rgba(0,0,0,0.06)];
		}
		:global(.dark) .quiz-actions {
			box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.25);
		}
		.quiz-nav-btn-label {
			@apply inline;
		}
	}

	/* ── Modal Examen / Retomar: entrada animada ─────────────────────── */
	.exam-modal-box {
		opacity: 0;
		transform: translateY(16px) scale(0.97);
		transition: opacity 0.22s ease, transform 0.22s ease;
	}
	#exam-modal:not(.hidden) .exam-modal-box,
	#resume-modal:not(.hidden) .exam-modal-box {
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	.results-badge--exam {
		@apply border-amber-500/30 bg-amber-500/10 text-amber-700 dark:text-amber-300;
	}
	.results-grid--exam {
