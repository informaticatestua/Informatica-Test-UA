	}

	.results-hero {
		@apply flex flex-col gap-3 rounded-2xl border border-border-subtle bg-surface-hover/80 p-5 sm:p-6 mb-5;
	}
	.results-badge {
		@apply inline-flex items-center gap-2 self-start rounded-full border border-emerald-500/30 bg-emerald-500/10 px-3 py-1 text-[0.78rem] font-semibold text-emerald-700 dark:text-emerald-300;
	}
	.results-title {
		@apply m-0 font-heading text-2xl sm:text-3xl font-bold tracking-tight text-text-main;
	}
	.results-subtitle {
		@apply m-0 text-sm sm:text-base text-text-muted leading-relaxed;
	}
	.results-grid {
		@apply grid grid-cols-1 sm:grid-cols-3 gap-3 mb-5;
	}
	.results-stat-card {
		@apply rounded-xl border border-border-subtle bg-surface p-4 shadow-subtle;
	}
	.results-stat-label {
		@apply block text-[0.78rem] font-semibold uppercase tracking-wide text-text-muted mb-2;
	}
	.results-stat-value {
		@apply block font-heading text-3xl font-bold text-text-main;
	}
	.results-summary {
		@apply rounded-xl border border-border-subtle bg-surface p-4 sm:p-5 text-sm leading-relaxed text-text-main mb-5;
	}
	.results-actions {
		@apply flex flex-col sm:flex-row gap-3 justify-center sm:justify-start;
	}

	@media (max-width: 767px) {
		#app {
			@apply w-[95%]! p-[15px]! pb-[8px]! mt-[70px]!;
		}
		.btn, .btn-secondary, .btn-tertiary, .btn-ghost {
			@apply m-[5px]! px-[12px]! py-[8px]! text-[0.9em]!;
		}
		.btn-primary {
			@apply w-full! m-0! mb-[8px]! min-h-[52px]! text-[1.05em]! rounded-[8px]!;
		}
	}
	
	@media (max-width: 480px) {
		.btn, .btn-primary, .btn-secondary, .btn-tertiary, .btn-ghost {
			@apply text-[0.9em]!;
		}
		.btn-primary {
			@apply min-h-[56px]! text-[1.05em]!;
		}
	}

	/* ── Botón Generar quiz con IA ─────────────────────────────────── */
	.btn-aigen {
		@apply flex items-center gap-1.5 text-violet-600 dark:text-violet-400
			   border-violet-400/60 dark:border-violet-500/50
			   hover:bg-violet-50 dark:hover:bg-violet-900/20 hover:border-violet-500;
	}

	/* ── Modal Report: entrada animada ───────────────────────────────── */
	.report-modal-box {
		opacity: 0;
		transform: translateY(16px) scale(0.97);
		transition: opacity 0.22s ease, transform 0.22s ease;
	}
	#report-modal:not(.hidden) .report-modal-box {
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	/* ── Modal AI Generate: entrada animada ──────────────────────────── */
	.aigen-modal-box {
		opacity: 0;
		transform: translateY(16px) scale(0.97);
		transition: opacity 0.24s ease, transform 0.24s ease;
	}
	#aigen-modal:not(.hidden) .aigen-modal-box {
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	/* ── Botón "Generar preguntas" ────────────────────────────────────── */
	.aigen-generate-btn {
		background: linear-gradient(135deg, #7c3aed, #6d28d9);
		color: white;
		box-shadow: 0 4px 14px rgba(124, 58, 237, 0.35);
	}
	.aigen-generate-btn:hover {
		background: linear-gradient(135deg, #6d28d9, #5b21b6);
		box-shadow: 0 6px 20px rgba(124, 58, 237, 0.45);
		transform: translateY(-1px);
	}
	.aigen-generate-btn:active {
		transform: translateY(0);
		box-shadow: 0 2px 8px rgba(124, 58, 237, 0.3);
	}

	/* ── Slider personalizado ─────────────────────────────────────────── */
	.aigen-slider {
		-webkit-appearance: none;
		appearance: none;
		width: 100%;
		height: 8px;
		border-radius: 4px;
		cursor: pointer;
		outline: none;
		background: linear-gradient(
			to right,
			#7c3aed var(--aigen-fill, 8%),
			rgb(var(--border-subtle)) var(--aigen-fill, 8%)
		);
		transition: background 0.1s ease;
	}
	.aigen-slider::-webkit-slider-thumb {
		-webkit-appearance: none;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		background: #7c3aed;
		border: 3px solid rgb(var(--bg-surface));
		box-shadow: 0 0 0 2px #7c3aed, 0 2px 8px rgba(124, 58, 237, 0.45);
		cursor: pointer;
		transition: transform 0.12s ease, box-shadow 0.12s ease;
	}
	.aigen-slider:hover::-webkit-slider-thumb,
	.aigen-slider:focus::-webkit-slider-thumb {
		transform: scale(1.12);
		box-shadow: 0 0 0 2px #7c3aed, 0 4px 14px rgba(124, 58, 237, 0.55);
	}
	.aigen-slider:active::-webkit-slider-thumb {
		transform: scale(1.05);
	}
	.aigen-slider::-moz-range-thumb {
		width: 24px;
		height: 24px;
		border-radius: 50%;
		background: #7c3aed;
		border: 3px solid rgb(var(--bg-surface));
		box-shadow: 0 0 0 2px #7c3aed, 0 2px 8px rgba(124, 58, 237, 0.45);
		cursor: pointer;
	}
	.aigen-slider::-moz-range-track {
		height: 8px;
		border-radius: 4px;
		background: rgb(var(--border-subtle));
	}

	/* ── Spinner violeta ──────────────────────────────────────────────── */
	.aigen-spinner {
		width: 36px;
		height: 36px;
		border: 3px solid rgba(124, 58, 237, 0.2);
		border-top-color: #7c3aed;
		border-radius: 50%;
		animation: aigen-spin 0.75s linear infinite;
	}
	@keyframes aigen-spin {
		to { transform: rotate(360deg); }
	}

	/* ── Badge de rango ───────────────────────────────────────────────── */
	.aigen-range-badge {
		display: inline-flex;
		align-items: center;
		font-size: 0.65rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding: 2px 8px;
		border-radius: 999px;
		transition: background-color 0.2s ease, color 0.2s ease;
	}
	.aigen-range-badge--fast  { background: rgba(124, 58, 237, 0.1); color: #7c3aed; }
	.aigen-range-badge--std   { background: rgba(59, 130, 246, 0.1); color: #3b82f6; }
	.aigen-range-badge--large { background: rgba(245, 158, 11, 0.1); color: #d97706; }
	:global(.dark) .aigen-range-badge--fast  { background: rgba(167, 139, 250, 0.15); color: #a78bfa; }
	:global(.dark) .aigen-range-badge--std   { background: rgba(96, 165, 250, 0.15);  color: #60a5fa; }
	:global(.dark) .aigen-range-badge--large { background: rgba(251, 191, 36, 0.15);  color: #fbbf24; }

	/* ── Tarjetas de opción múltiple ──────────────────────────────── */
