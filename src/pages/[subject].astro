---
import BaseLayout from '../layouts/BaseLayout.astro';

const { subject } = Astro.params;
const subjectTitle = subject ? subject.toUpperCase().replace(/-/g, ' ') : 'Test';
---


<BaseLayout title={`${subjectTitle} • Tests UA`}>
	<div id="main-container" class="flex flex-col items-center justify-center m-auto w-full">
		<div id="app" class="relative w-max max-w-[95vw] text-center bg-surface shadow-md shadow-black/5 rounded-[5px] px-[40px] py-[30px] mx-auto my-[20px] box-border border border-border-subtle">
			
			<div class="absolute top-[10px] right-[10px] sm:top-[15px] sm:right-[15px] flex items-center justify-end gap-1.5 z-10 w-full sm:w-auto pr-[10px] sm:pr-0 pl-[40px] pointer-events-none">
				<button id="explicar-ia-btn"  class="pointer-events-auto p-[7px] bg-gradient-to-br from-blue-500 to-violet-600 text-white rounded-[8px] shadow-sm hover:shadow-md hover:-translate-y-px transition-all flex items-center justify-center cursor-pointer border-none disabled:opacity-40 disabled:cursor-not-allowed" title="Explicar con IA" disabled>
					<span class="material-icons mi-lg">auto_awesome</span>
				</button>
				<button id="report-btn"  class="pointer-events-auto p-[7px] bg-surface border border-border-subtle rounded-[8px] text-text-muted hover:text-red-500 hover:border-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors flex items-center justify-center group cursor-pointer" title="Reportar un error en esta pregunta">
					<span class="material-icons mi-sm group-hover:text-red-500 transition-colors">flag</span>
				</button>
				<button id="copyButton" class="pointer-events-auto p-[7px] bg-surface z-10 border border-border-subtle rounded-[8px] text-text-muted hover:text-text-main hover:bg-surface-hover transition-colors flex items-center justify-center cursor-pointer" class="hidden" title="Copiar pregunta">
					<span class="material-icons mi-sm">content_copy</span>
					<span id="copyText" class="sr-only">Copiar</span>
				</button>
			</div>

			<div id="pregunta" class="text-left text-[0.95em] md:text-[1em] mb-[15px] mt-[25px] sm:mt-[5px] sm:pr-[180px]"></div>

			<div id="report-warning" class="report-warning hidden" role="status" aria-live="polite" aria-atomic="true"></div>

			<form id="opciones" class="text-left flex flex-col mt-[1em] w-full gap-[10px] sm:gap-[12px] min-w-[300px]"></form>

			<div id="resultado" class="mt-[15px] font-semibold text-center min-h-[24px]"></div>

			<section id="session-results" class="hidden text-left">
				<div class="results-hero">
					<div class="results-badge">
						<span class="material-icons">emoji_events</span>
						<span>Sesión completada</span>
					</div>
					<h3 id="results-title" class="results-title">Buen trabajo</h3>
					<p id="results-subtitle" class="results-subtitle">Has terminado este módulo.</p>
				</div>

				<div class="results-grid">
					<article class="results-stat-card">
						<span class="results-stat-label">Aciertos</span>
						<strong id="results-correct" class="results-stat-value">0</strong>
					</article>
					<article class="results-stat-card">
						<span class="results-stat-label">Fallos</span>
						<strong id="results-incorrect" class="results-stat-value">0</strong>
					</article>
					<article class="results-stat-card">
						<span class="results-stat-label">Precisión</span>
						<strong id="results-accuracy" class="results-stat-value">0%</strong>
					</article>
				</div>

				<div id="results-summary" class="results-summary"></div>

				<div class="results-actions">
					<button id="results-restart-btn" class="btn-primary mt-0! w-full sm:w-auto">Repetir módulo</button>
					<button id="results-review-btn" class="btn-secondary mt-0! w-full sm:w-auto">Repasar fallos</button>
					<button id="results-resumen-btn" class="btn mt-0! w-full sm:w-auto">Ver resumen</button>
				</div>
			</section>

			<!-- ── Resultados del modo examen ─────────────────────────────────── -->
			<section id="exam-results" class="hidden text-left">
				<div class="results-hero">
					<div class="results-badge results-badge--exam">
						<span class="material-icons">timer</span>
						<span>Examen finalizado</span>
					</div>
					<h3 id="exam-results-title" class="results-title">Resultados del examen</h3>
					<p id="exam-results-subtitle" class="results-subtitle"></p>
				</div>

				<div class="results-grid results-grid--exam">
					<article class="results-stat-card">
						<span class="results-stat-label">Nota</span>
						<strong id="exam-score" class="results-stat-value">0</strong>
					</article>
					<article class="results-stat-card">
						<span class="results-stat-label">Tiempo</span>
						<strong id="exam-time" class="results-stat-value">0:00</strong>
					</article>
					<article class="results-stat-card">
						<span class="results-stat-label">Aciertos</span>
						<strong id="exam-correct" class="results-stat-value text-green-600 dark:text-green-400">0</strong>
					</article>
					<article class="results-stat-card">
						<span class="results-stat-label">Fallos</span>
						<strong id="exam-wrong" class="results-stat-value text-red-600 dark:text-red-400">0</strong>
					</article>
					<article class="results-stat-card">
						<span class="results-stat-label">En blanco</span>
						<strong id="exam-blank" class="results-stat-value">0</strong>
					</article>
				</div>

				<div class="flex items-center gap-3 mb-4 mt-2">
					<div class="flex-1 h-px bg-border-subtle"></div>
					<span class="text-[0.7rem] text-text-muted font-semibold uppercase tracking-wider">Desglose pregunta a pregunta</span>
					<div class="flex-1 h-px bg-border-subtle"></div>
				</div>
				<div id="exam-breakdown" class="space-y-3 mb-5"></div>

				<div class="results-actions">
					<button id="exam-exit-btn" class="btn-primary mt-0! w-full sm:w-auto">Volver al modo test</button>
					<button id="exam-retry-btn" class="btn-secondary mt-0! w-full sm:w-auto">Repetir examen</button>
				</div>
			</section>
			
			<div id="action-buttons-container" class="quiz-actions">
				<div class="quiz-actions-primary">
					<button id="volver-pregunta" class="quiz-nav-btn hidden" aria-label="Pregunta anterior">
						<span class="material-icons" aria-hidden="true">chevron_left</span>
						<span class="quiz-nav-btn-label">Anterior</span>
					</button>
					<button id="verificar" class="hidden quiz-verify-btn" disabled>Verificar / Continuar</button>
					<div id="tools-trigger-wrap" class="w-full sm:w-auto">
						<button id="more-options-btn" class="quiz-nav-btn w-full sm:w-auto" aria-haspopup="dialog" aria-expanded="false" aria-controls="tools-sheet-panel">
							<span class="material-icons" aria-hidden="true">apps</span>
							<span class="quiz-nav-btn-label">Herramientas</span>
						</button>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Panel de herramientas: rejilla fija, sin scroll de página -->
	<div id="tools-sheet" class="tools-sheet" aria-hidden="true">
		<div id="tools-sheet-backdrop" class="tools-sheet-backdrop"></div>
		<div id="tools-sheet-panel" class="tools-sheet-panel" role="dialog" aria-modal="true" aria-labelledby="tools-sheet-title">
			<div class="tools-sheet-handle" aria-hidden="true"></div>
			<header class="tools-sheet-header">
				<div>
					<h3 id="tools-sheet-title" class="tools-sheet-title">Herramientas del test</h3>
					<p class="tools-sheet-subtitle">Modos de estudio y accesos rápidos</p>
				</div>
				<button id="tools-sheet-close" type="button" class="tools-sheet-close" aria-label="Cerrar herramientas">
					<span class="material-icons">close</span>
				</button>
			</header>
			<div class="tools-sheet-body">
				<div id="tools-quiz-section" class="tools-sheet-section">
					<p class="tools-sheet-section-label">Estudio</p>
					<div class="tools-sheet-grid">
						<button id="resumenBtn" type="button" class="tools-sheet-item" class="hidden">
							<span class="tools-sheet-icon tools-sheet-icon--blue"><span class="material-icons">summarize</span></span>
							<span class="tools-sheet-item-text">
								<span class="tools-sheet-item-label">Resumen</span>
								<span class="tools-sheet-item-desc">Todas las preguntas</span>
							</span>
						</button>
						<button id="review-errors-btn" type="button" class="tools-sheet-item" class="hidden">
							<span class="tools-sheet-icon tools-sheet-icon--amber"><span class="material-icons">refresh</span></span>
							<span class="tools-sheet-item-text">
								<span id="review-errors-label" class="tools-sheet-item-label">Repasar fallos</span>
								<span class="tools-sheet-item-desc">Solo las incorrectas</span>
							</span>
						</button>
						<button id="aigen-open-btn" type="button" class="tools-sheet-item tools-sheet-item--accent" class="hidden" aria-label="Generar quiz con IA">
							<span class="tools-sheet-icon tools-sheet-icon--violet"><span class="material-icons">psychology</span></span>
							<span class="tools-sheet-item-text">
								<span class="tools-sheet-item-label">Quiz con IA</span>
								<span class="tools-sheet-item-desc">Preguntas nuevas</span>
							</span>
						</button>
						<button id="exam-open-btn" type="button" class="tools-sheet-item tools-sheet-item--accent" class="hidden" aria-label="Modo examen real">
							<span class="tools-sheet-icon tools-sheet-icon--orange"><span class="material-icons">timer</span></span>
							<span class="tools-sheet-item-text">
								<span class="tools-sheet-item-label">Modo examen</span>
								<span class="tools-sheet-item-desc">Simulacro real</span>
							</span>
						</button>
					</div>
				</div>
				<div class="tools-sheet-section">
					<p class="tools-sheet-section-label">Comunidad</p>
					<div class="tools-sheet-grid">
						<button id="contribute-btn" type="button" class="tools-sheet-item" aria-label="Contribuir una pregunta">
							<span class="tools-sheet-icon tools-sheet-icon--green"><span class="material-icons">add_circle_outline</span></span>
							<span class="tools-sheet-item-text">
								<span class="tools-sheet-item-label">Contribuir</span>
								<span class="tools-sheet-item-desc">Añadir pregunta</span>
							</span>
						</button>
						<button id="forum-btn" type="button" class="tools-sheet-item" aria-label="Foro de la asignatura">
							<span class="tools-sheet-icon tools-sheet-icon--slate"><span class="material-icons">forum</span></span>
							<span class="tools-sheet-item-text">
								<span class="tools-sheet-item-label">Foro</span>
								<span class="tools-sheet-item-desc">Dudas y debate</span>
							</span>
						</button>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div id="stats-panel" class="hidden fixed bottom-[10px] right-[10px] z-50 flex items-center gap-2.5 bg-surface/90 text-text-main text-[13px] px-[14px] py-[8px] rounded-full border border-border-subtle shadow-md shadow-black/10 backdrop-blur-sm">
		<span class="material-icons mi-sm text-text-muted">bar_chart</span>
		<span id="total-preguntas" class="font-medium whitespace-nowrap"></span>
		<span class="w-px h-4 bg-border-subtle" aria-hidden="true"></span>
		<span id="contador" class="font-medium whitespace-nowrap"></span>
	</div>

	<!-- Cronómetro del modo examen -->
	<div id="exam-timer-chip" class="hidden fixed top-[80px] right-[10px] z-50 flex items-center gap-2 bg-amber-500/95 text-white text-[14px] px-[14px] py-[8px] rounded-full shadow-md shadow-black/15 backdrop-blur-sm font-semibold tabular-nums">
		<span class="material-icons text-[17px]">timer</span>
		<span id="exam-timer-label">0:00</span>
	</div>

	<!-- ─── AI Generate overlay ─────────────────────────────────────────── -->
	<div id="aigen-overlay" class="hidden fixed inset-0 z-[300] bg-black/60 backdrop-blur-sm"></div>

	<!-- ─── AI Generate modal ────────────────────────────────────────────── -->
	<div id="aigen-modal" class="hidden fixed inset-0 z-[301] flex items-center justify-center p-4" role="dialog" aria-modal="true" aria-labelledby="aigen-title">
		<div class="aigen-modal-box w-full max-w-md bg-surface rounded-2xl shadow-2xl border border-border-subtle overflow-hidden">
			<div class="h-1 w-full bg-gradient-to-r from-violet-500 via-purple-500 to-blue-500"></div>
			<div class="p-5 sm:p-6">

				<!-- Cabecera -->
				<div class="flex items-start justify-between mb-5">
					<div class="flex items-center gap-3">
						<div class="flex items-center justify-center w-10 h-10 rounded-xl bg-violet-100 dark:bg-violet-900/40 flex-shrink-0">
							<span class="material-icons text-violet-600 dark:text-violet-400">psychology</span>
						</div>
						<div>
							<h3 id="aigen-title" class="font-heading font-bold text-text-main text-base m-0 leading-tight">Generar quiz con IA</h3>
							<p class="text-text-muted text-xs mt-0.5 m-0">Preguntas nuevas sobre esta asignatura</p>
						</div>
					</div>
					<button id="aigen-close" class="p-1 text-text-muted hover:text-text-main rounded-full hover:bg-surface-hover transition-colors cursor-pointer border-none bg-transparent flex-shrink-0" aria-label="Cerrar">
						<span class="material-icons">close</span>
					</button>
				</div>

				<!-- ── Estado: Configuración ────────────────────────────────── -->
				<div id="aigen-config">

					<!-- Proveedor activo -->
					<div class="flex items-center gap-2 p-3 mb-5 bg-surface-hover rounded-xl border border-border-subtle text-sm">
						<span class="material-icons text-violet-500" style="font-size:1rem;">auto_awesome</span>
						<span class="text-text-muted text-xs">Proveedor:</span>
						<span id="aigen-provider-label" class="text-text-main text-xs font-semibold flex-1"></span>
						<a id="aigen-config-link" href="#" class="text-xs text-blue-500 hover:text-blue-600 underline decoration-dotted">Cambiar</a>
					</div>

					<!-- Slider -->
					<div class="mb-6">
						<div class="flex items-end justify-between mb-3 gap-2">
							<span class="text-sm font-semibold text-text-main">Número de preguntas</span>
							<div class="flex items-baseline gap-2">
								<span id="aigen-range-label" class="aigen-range-badge aigen-range-badge--fast">Rápido</span>
								<span class="flex items-baseline gap-1">
									<span id="aigen-count" class="text-[2rem] font-heading font-bold text-violet-600 dark:text-violet-400 tabular-nums leading-none">20</span>
									<span class="text-text-muted text-xs">preg.</span>
								</span>
							</div>
						</div>

						<div class="relative py-2">
							<input
								id="aigen-slider"
								type="range" min="5" max="200" step="5" value="20"
								class="aigen-slider w-full"
								aria-label="Número de preguntas a generar"
								aria-valuemin="5" aria-valuemax="200" aria-valuenow="20"
							/>
						</div>

						<div class="flex justify-between mt-1">
							<span class="text-text-muted text-[0.68rem]">5</span>
							<span class="text-text-muted text-[0.68rem]">50</span>
							<span class="text-text-muted text-[0.68rem]">100</span>
							<span class="text-text-muted text-[0.68rem]">150</span>
							<span class="text-text-muted text-[0.68rem]">200</span>
						</div>
					</div>

					<!-- Aviso para números grandes -->
					<div id="aigen-token-warning" class="hidden mb-4 p-3 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700/60 rounded-xl">
						<div class="flex items-start gap-2">
							<span class="material-icons text-amber-500 flex-shrink-0 mt-0.5" style="font-size:1rem;">warning_amber</span>
							<p class="text-amber-800 dark:text-amber-300 text-xs m-0 leading-relaxed">
								Con más de 80 preguntas la generación puede tardar varios minutos y consumir muchos tokens. Asegúrate de que tu plan de API lo permite.
							</p>
						</div>
					</div>

					<!-- Error -->
					<div id="aigen-error-box" class="hidden mb-4 p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700/60 rounded-xl">
						<div class="flex items-start gap-2">
							<span class="material-icons text-red-500 flex-shrink-0 mt-0.5" style="font-size:1rem;">error_outline</span>
							<p id="aigen-error-msg" class="text-red-700 dark:text-red-400 text-xs m-0 leading-relaxed"></p>
						</div>
					</div>

					<!-- Botón generar -->
					<button id="aigen-generate-btn" class="aigen-generate-btn w-full py-3 rounded-xl text-sm font-semibold cursor-pointer border-none flex items-center justify-center gap-2 transition-all">
						<span class="material-icons" style="font-size:1.1rem;">auto_fix_high</span>
						Generar preguntas
					</button>
				</div>

				<!-- ── Estado: Generando ─────────────────────────────────────── -->
				<div id="aigen-generating" class="hidden">
					<div class="flex flex-col items-center py-8 gap-4">
						<div class="aigen-spinner"></div>
						<div class="text-center">
							<p id="aigen-progress-text" class="text-text-muted text-sm m-0">Conectando con la IA…</p>
							<p class="text-text-muted text-xs mt-1 m-0">Esto puede tardar unos segundos</p>
						</div>
						<button id="aigen-cancel-btn" class="mt-2 text-text-muted hover:text-text-main text-xs underline decoration-dotted cursor-pointer bg-transparent border-none transition-colors">
							Cancelar
						</button>
					</div>
				</div>

				<!-- ── Estado: Éxito ────────────────────────────────────────── -->
				<div id="aigen-success" class="hidden">
					<div class="flex flex-col items-center py-6 gap-4 text-center">
						<div class="w-14 h-14 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
							<span class="material-icons text-green-600 dark:text-green-400" style="font-size:1.8rem;">check_circle</span>
						</div>
						<div>
							<p class="text-text-main font-heading font-bold text-lg m-0">¡Quiz listo!</p>
							<p class="text-text-muted text-sm mt-1 m-0">
								<span id="aigen-success-count" class="font-bold text-text-main">0</span> preguntas nuevas generadas
							</p>
						</div>
						<div class="w-full flex flex-col gap-2 pt-2">
							<button id="aigen-start-btn" class="w-full py-3 bg-green-600 hover:bg-green-700 text-white rounded-xl text-sm font-semibold transition-colors cursor-pointer border-none flex items-center justify-center gap-2">
								<span class="material-icons" style="font-size:1.1rem;">play_arrow</span>
								Iniciar quiz con estas preguntas
							</button>
							<button id="aigen-regenerate-btn" class="w-full py-2.5 bg-transparent hover:bg-surface-hover text-text-muted hover:text-text-main border border-border-subtle rounded-xl text-sm font-medium transition-colors cursor-pointer flex items-center justify-center gap-1.5">
								<span class="material-icons" style="font-size:1rem;">refresh</span>
								Generar de nuevo
							</button>
						</div>
					</div>
				</div>

			</div>
		</div>
	</div>

	<!-- ─── AI Explanation Drawer ────────────────────────────────────────── -->
	<div id="ai-drawer" class="ai-drawer" aria-hidden="true">
		<div id="ai-drawer-backdrop" class="ai-drawer-backdrop"></div>
		<div id="ai-drawer-panel" class="ai-drawer-panel">

			<!-- Drag handle (solo móvil) -->
			<div class="flex justify-center pt-3 pb-1 sm:hidden flex-shrink-0">
				<div class="w-10 h-1 rounded-full bg-border-subtle"></div>
			</div>

			<!-- Cabecera del panel -->
			<div class="flex items-center justify-between px-5 py-3 border-b border-border-subtle flex-shrink-0">
				<div class="flex items-center gap-2">
					<span class="material-icons text-blue-500" style="font-size:1.2rem;">auto_awesome</span>
					<span class="font-heading font-bold text-text-main text-[0.95rem]">Explicación IA</span>
				</div>
				<div class="flex items-center gap-1.5">
					<select id="ai-drawer-provider" class="ai-drawer-select" aria-label="Proveedor de IA">
						<option value="gemini">Gemini</option>
						<option value="groq">Groq</option>
						<option value="deepseek">DeepSeek</option>
					</select>
					<select id="ai-drawer-model" class="ai-drawer-select" aria-label="Modelo de IA"></select>
					<button id="ai-drawer-close" class="ml-1 p-1 text-text-muted hover:text-text-main hover:bg-surface-hover rounded-full transition-colors cursor-pointer border-none bg-transparent" aria-label="Cerrar panel">
						<span class="material-icons" style="font-size:1.3rem;">close</span>
					</button>
				</div>
			</div>

			<!-- Contenido con scroll -->
			<div class="overflow-y-auto flex-1 px-5 py-4">

				<!-- Resumen de la pregunta -->
				<div id="ai-question-summary" class="mb-4 p-4 bg-surface-hover rounded-xl border border-border-subtle text-sm leading-relaxed"></div>

				<!-- Separador -->
				<div class="flex items-center gap-3 mb-4">
					<div class="flex-1 h-px bg-border-subtle"></div>
					<span class="text-[0.7rem] text-text-muted font-semibold uppercase tracking-wider">Explicación</span>
					<div class="flex-1 h-px bg-border-subtle"></div>
				</div>

				<!-- Loading -->
				<div id="ai-loading" class="hidden flex flex-col items-center justify-center py-10 gap-3">
					<div class="ai-spinner"></div>
					<span class="text-text-muted text-sm">Generando explicación...</span>
				</div>

				<!-- Error -->
				<div id="ai-error" class="hidden p-4 bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 rounded-xl mb-3">
					<div class="flex items-center gap-2 mb-1">
						<span class="material-icons text-red-500" style="font-size:1rem;">error_outline</span>
						<span class="font-semibold text-red-700 dark:text-red-400 text-sm">Error al generar la explicación</span>
					</div>
					<p id="ai-error-msg" class="text-red-600 dark:text-red-400 text-xs m-0 leading-relaxed"></p>
				</div>

				<!-- Texto de la IA (streaming) -->
				<div id="ai-text" class="text-text-main text-sm leading-relaxed" data-raw=""></div>

				<!-- Botón reintentar -->
