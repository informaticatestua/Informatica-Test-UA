---
import BaseLayout from '../layouts/BaseLayout.astro';

const { subject } = Astro.params;
const subjectTitle = subject ? subject.toUpperCase().replace(/-/g, ' ') : 'Test';
---


<BaseLayout title={`${subjectTitle} • Tests UA`}>
	<div id="main-container" class="flex flex-col items-center justify-center m-auto w-full">
		<div id="app" class="relative w-max max-w-[95vw] text-center bg-surface shadow-md shadow-black/5 rounded-[5px] px-[40px] py-[30px] mx-auto my-[20px] box-border border border-border-subtle">
			
			<div class="absolute top-[10px] right-[10px] sm:top-[15px] sm:right-[15px] flex items-center justify-end gap-2 z-10 w-full sm:w-auto pr-[10px] sm:pr-0 pl-[40px] pointer-events-none">
				<button id="report-btn" class="pointer-events-auto px-[8px] py-[4px] bg-surface border border-border-subtle rounded-[5px] text-text-muted hover:text-red-500 hover:border-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors flex items-center justify-center gap-[5px] text-[0.85em] font-medium group cursor-pointer" title="Reportar un error">
					<span class="material-icons text-[16px] group-hover:text-red-500 transition-colors">flag</span>
					<span class="hidden sm:inline">Reportar</span>
				</button>
				<button id="copyButton" class="pointer-events-auto px-[8px] py-[4px] bg-surface z-10 border border-border-subtle rounded-[5px] text-text-muted hover:text-text-main hover:bg-surface-hover transition-colors flex items-center justify-center gap-[5px] text-[0.85em] font-medium cursor-pointer" style="display: none">
					<span class="material-icons text-[16px]">content_copy</span>
					<span id="copyText">Copiar</span>
				</button>
			</div>

			<div id="pregunta" class="text-left text-[0.95em] md:text-[1em] mb-[15px] mt-[25px] sm:mt-[5px] sm:pr-[180px]"></div>
			<form id="opciones" class="text-left flex flex-col mt-[1em] w-full gap-[10px] sm:gap-[12px] min-w-[300px]"></form>
			
			<div id="resultado" class="mt-[15px] font-semibold text-center min-h-[24px]"></div>
			
			<div id="action-buttons-container" class="flex flex-col sm:flex-row justify-center sm:justify-between items-center gap-[12px] mt-[24px] w-full pt-[15px] sm:pt-[20px] border-t border-border-subtle">
				<!-- Fila secundaria móvil / Izquierda desktop -->
				<div class="order-3 sm:order-1 flex justify-center sm:justify-start items-center gap-[10px] w-full sm:w-auto">
					<button id="volver-pregunta" class="btn-ghost hidden mt-0!">← Anterior</button>
					<button id="saltar-pregunta" class="btn-ghost mt-0!" style="display: none;">Saltar →</button>
				</div>
				<!-- Fila principal móvil / Centro desktop -->
				<div class="order-1 sm:order-2 w-full sm:w-auto flex flex-col sm:flex-row justify-center items-center gap-2">
					<button id="verificar" class="hidden btn-primary mt-0! w-full sm:w-auto sm:min-w-[200px]" disabled>Verificar / Continuar</button>
					<button id="explicar-ia-btn" class="btn-explicar-ia" disabled onclick="window.AIFeatures?.showExplanation()">
						<span class="material-icons" style="font-size:1.1em;">auto_awesome</span>
						Explicar con IA
					</button>
				</div>
				<!-- Fila terciaria móvil / Derecha desktop -->
				<div class="order-2 sm:order-3 w-full sm:w-auto flex justify-center sm:justify-end">
					<button id="volver" class="btn-ghost mt-0!" onclick="window.location.href = '/'">Volver al Menú</button>
				</div>
			</div>
		</div>

		<div id="button-container" class="w-full flex justify-center gap-3 mt-[20px] flex-wrap">
			<button id="resumenBtn" class="btn" style="display: none">Resumen</button>
			<button id="aigen-open-btn" class="btn btn-aigen" style="display: none" aria-label="Generar quiz con IA">
				<span class="material-icons" style="font-size:1rem;">psychology</span>
				Generar quiz con IA
			</button>
		</div>
	</div>

	<div class="contador hidden fixed bottom-[10px] right-[10px] bg-black/50 text-white text-[14px] px-[10px] py-[5px] rounded-[5px] z-50 backdrop-blur-sm" id="contador">Correctas: 0 / Preguntas: 0</div>
	<div id="total-preguntas" class="bottom-left hidden fixed bottom-[10px] left-[10px] text-[16px] text-white bg-black/50 p-[5px] rounded-[3px] backdrop-blur-sm"></div>

	<!-- ─── AI Generate overlay ─────────────────────────────────────────── -->
	<div id="aigen-overlay" class="hidden fixed inset-0 z-[300] bg-black/60 backdrop-blur-sm"></div>

	<!-- ─── AI Generate modal ────────────────────────────────────────────── -->
	<div id="aigen-modal" class="hidden fixed inset-0 z-[301] flex items-center justify-center p-4" role="dialog" aria-modal="true" aria-labelledby="aigen-title">
		<div class="aigen-modal-box w-full max-w-md bg-surface rounded-2xl shadow-2xl border border-border-subtle overflow-hidden">
			<div class="h-1 w-full bg-gradient-to-r from-violet-500 via-purple-500 to-blue-500"></div>
			<div class="p-5 sm:p-6">

				<!-- Cabecera -->
				<div class="flex items-start justify-between mb-5">
					<div class="flex items-center gap-3">
						<div class="flex items-center justify-center w-10 h-10 rounded-xl bg-violet-100 dark:bg-violet-900/40 flex-shrink-0">
							<span class="material-icons text-violet-600 dark:text-violet-400">psychology</span>
						</div>
						<div>
							<h3 id="aigen-title" class="font-heading font-bold text-text-main text-base m-0 leading-tight">Generar quiz con IA</h3>
							<p class="text-text-muted text-xs mt-0.5 m-0">Preguntas nuevas sobre esta asignatura</p>
						</div>
					</div>
					<button id="aigen-close" class="p-1 text-text-muted hover:text-text-main rounded-full hover:bg-surface-hover transition-colors cursor-pointer border-none bg-transparent flex-shrink-0" aria-label="Cerrar">
						<span class="material-icons">close</span>
					</button>
				</div>

				<!-- ── Estado: Configuración ────────────────────────────────── -->
				<div id="aigen-config">

					<!-- Proveedor activo -->
					<div class="flex items-center gap-2 p-3 mb-5 bg-surface-hover rounded-xl border border-border-subtle text-sm">
						<span class="material-icons text-violet-500" style="font-size:1rem;">auto_awesome</span>
						<span class="text-text-muted text-xs">Proveedor:</span>
						<span id="aigen-provider-label" class="text-text-main text-xs font-semibold flex-1"></span>
						<a id="aigen-config-link" href="#" class="text-xs text-blue-500 hover:text-blue-600 underline decoration-dotted">Cambiar</a>
					</div>

					<!-- Slider -->
					<div class="mb-6">
						<div class="flex items-end justify-between mb-3 gap-2">
							<span class="text-sm font-semibold text-text-main">Número de preguntas</span>
							<div class="flex items-baseline gap-2">
								<span id="aigen-range-label" class="aigen-range-badge aigen-range-badge--fast">Rápido</span>
								<span class="flex items-baseline gap-1">
									<span id="aigen-count" class="text-[2rem] font-heading font-bold text-violet-600 dark:text-violet-400 tabular-nums leading-none">20</span>
									<span class="text-text-muted text-xs">preg.</span>
								</span>
							</div>
						</div>

						<div class="relative py-2">
							<input
								id="aigen-slider"
								type="range" min="5" max="200" step="5" value="20"
								class="aigen-slider w-full"
								aria-label="Número de preguntas a generar"
								aria-valuemin="5" aria-valuemax="200" aria-valuenow="20"
							/>
						</div>

						<div class="flex justify-between mt-1">
							<span class="text-text-muted text-[0.68rem]">5</span>
							<span class="text-text-muted text-[0.68rem]">50</span>
							<span class="text-text-muted text-[0.68rem]">100</span>
							<span class="text-text-muted text-[0.68rem]">150</span>
							<span class="text-text-muted text-[0.68rem]">200</span>
						</div>
					</div>

					<!-- Aviso para números grandes -->
					<div id="aigen-token-warning" class="hidden mb-4 p-3 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700/60 rounded-xl">
						<div class="flex items-start gap-2">
							<span class="material-icons text-amber-500 flex-shrink-0 mt-0.5" style="font-size:1rem;">warning_amber</span>
							<p class="text-amber-800 dark:text-amber-300 text-xs m-0 leading-relaxed">
								Con más de 80 preguntas la generación puede tardar varios minutos y consumir muchos tokens. Asegúrate de que tu plan de API lo permite.
							</p>
						</div>
					</div>

					<!-- Error -->
					<div id="aigen-error-box" class="hidden mb-4 p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700/60 rounded-xl">
						<div class="flex items-start gap-2">
							<span class="material-icons text-red-500 flex-shrink-0 mt-0.5" style="font-size:1rem;">error_outline</span>
							<p id="aigen-error-msg" class="text-red-700 dark:text-red-400 text-xs m-0 leading-relaxed"></p>
						</div>
					</div>

					<!-- Botón generar -->
					<button id="aigen-generate-btn" class="aigen-generate-btn w-full py-3 rounded-xl text-sm font-semibold cursor-pointer border-none flex items-center justify-center gap-2 transition-all">
						<span class="material-icons" style="font-size:1.1rem;">auto_fix_high</span>
						Generar preguntas
					</button>
				</div>

				<!-- ── Estado: Generando ─────────────────────────────────────── -->
				<div id="aigen-generating" class="hidden">
					<div class="flex flex-col items-center py-8 gap-4">
						<div class="aigen-spinner"></div>
						<div class="text-center">
							<p id="aigen-progress-text" class="text-text-muted text-sm m-0">Conectando con la IA…</p>
							<p class="text-text-muted text-xs mt-1 m-0">Esto puede tardar unos segundos</p>
						</div>
						<button id="aigen-cancel-btn" class="mt-2 text-text-muted hover:text-text-main text-xs underline decoration-dotted cursor-pointer bg-transparent border-none transition-colors">
							Cancelar
						</button>
					</div>
				</div>

				<!-- ── Estado: Éxito ────────────────────────────────────────── -->
				<div id="aigen-success" class="hidden">
					<div class="flex flex-col items-center py-6 gap-4 text-center">
						<div class="w-14 h-14 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
							<span class="material-icons text-green-600 dark:text-green-400" style="font-size:1.8rem;">check_circle</span>
						</div>
						<div>
							<p class="text-text-main font-heading font-bold text-lg m-0">¡Quiz listo!</p>
							<p class="text-text-muted text-sm mt-1 m-0">
								<span id="aigen-success-count" class="font-bold text-text-main">0</span> preguntas nuevas generadas
							</p>
						</div>
						<div class="w-full flex flex-col gap-2 pt-2">
							<button id="aigen-start-btn" class="w-full py-3 bg-green-600 hover:bg-green-700 text-white rounded-xl text-sm font-semibold transition-colors cursor-pointer border-none flex items-center justify-center gap-2">
								<span class="material-icons" style="font-size:1.1rem;">play_arrow</span>
								Iniciar quiz con estas preguntas
							</button>
							<button id="aigen-regenerate-btn" class="w-full py-2.5 bg-transparent hover:bg-surface-hover text-text-muted hover:text-text-main border border-border-subtle rounded-xl text-sm font-medium transition-colors cursor-pointer flex items-center justify-center gap-1.5">
								<span class="material-icons" style="font-size:1rem;">refresh</span>
								Generar de nuevo
							</button>
						</div>
					</div>
				</div>

			</div>
		</div>
	</div>

	<!-- ─── AI Explanation Drawer ────────────────────────────────────────── -->
	<div id="ai-drawer" class="ai-drawer" aria-hidden="true">
		<div id="ai-drawer-backdrop" class="ai-drawer-backdrop"></div>
		<div id="ai-drawer-panel" class="ai-drawer-panel">

			<!-- Drag handle (solo móvil) -->
			<div class="flex justify-center pt-3 pb-1 sm:hidden flex-shrink-0">
				<div class="w-10 h-1 rounded-full bg-border-subtle"></div>
			</div>

			<!-- Cabecera del panel -->
			<div class="flex items-center justify-between px-5 py-3 border-b border-border-subtle flex-shrink-0">
				<div class="flex items-center gap-2">
					<span class="material-icons text-blue-500" style="font-size:1.2rem;">auto_awesome</span>
					<span class="font-heading font-bold text-text-main text-[0.95rem]">Explicación IA</span>
				</div>
				<div class="flex items-center gap-1.5">
					<select id="ai-drawer-provider" class="ai-drawer-select" aria-label="Proveedor de IA">
						<option value="gemini">Gemini</option>
						<option value="groq">Groq</option>
						<option value="deepseek">DeepSeek</option>
					</select>
					<select id="ai-drawer-model" class="ai-drawer-select" aria-label="Modelo de IA"></select>
					<button id="ai-drawer-close" class="ml-1 p-1 text-text-muted hover:text-text-main hover:bg-surface-hover rounded-full transition-colors cursor-pointer border-none bg-transparent" aria-label="Cerrar panel">
						<span class="material-icons" style="font-size:1.3rem;">close</span>
					</button>
				</div>
			</div>

			<!-- Contenido con scroll -->
			<div class="overflow-y-auto flex-1 px-5 py-4">

				<!-- Resumen de la pregunta -->
				<div id="ai-question-summary" class="mb-4 p-4 bg-surface-hover rounded-xl border border-border-subtle text-sm leading-relaxed"></div>

				<!-- Separador -->
				<div class="flex items-center gap-3 mb-4">
					<div class="flex-1 h-px bg-border-subtle"></div>
					<span class="text-[0.7rem] text-text-muted font-semibold uppercase tracking-wider">Explicación</span>
					<div class="flex-1 h-px bg-border-subtle"></div>
				</div>

				<!-- Loading -->
				<div id="ai-loading" class="hidden flex flex-col items-center justify-center py-10 gap-3">
					<div class="ai-spinner"></div>
					<span class="text-text-muted text-sm">Generando explicación...</span>
				</div>

				<!-- Error -->
				<div id="ai-error" class="hidden p-4 bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 rounded-xl mb-3">
					<div class="flex items-center gap-2 mb-1">
						<span class="material-icons text-red-500" style="font-size:1rem;">error_outline</span>
						<span class="font-semibold text-red-700 dark:text-red-400 text-sm">Error al generar la explicación</span>
					</div>
					<p id="ai-error-msg" class="text-red-600 dark:text-red-400 text-xs m-0 leading-relaxed"></p>
				</div>

				<!-- Texto de la IA (streaming) -->
				<div id="ai-text" class="text-text-main text-sm leading-relaxed" data-raw=""></div>

				<!-- Botón reintentar -->
				<button id="ai-retry-btn" class="hidden mt-4 w-full py-2 px-4 border border-border-subtle rounded-lg text-text-muted hover:text-text-main hover:bg-surface-hover text-sm font-medium transition-colors cursor-pointer bg-transparent flex items-center justify-center gap-1.5">
					<span class="material-icons" style="font-size:1rem;">refresh</span>
					Reintentar
				</button>

				<!-- ── Chat de seguimiento ──────────────────────────────────── -->
				<div id="ai-chat-section" class="hidden mt-5">
					<div class="flex items-center gap-3 mb-4">
						<div class="flex-1 h-px bg-border-subtle"></div>
						<span class="text-[0.7rem] text-text-muted font-semibold uppercase tracking-wider">Continuar conversación</span>
						<div class="flex-1 h-px bg-border-subtle"></div>
					</div>
					<div id="ai-chat-history" class="flex flex-col gap-3 mb-3"></div>
					<div class="flex gap-2 items-end">
						<textarea
							id="ai-chat-input"
							rows="2"
							placeholder="¿Tienes alguna duda sobre la explicación?"
							class="flex-1 px-3 py-2 rounded-lg bg-background border border-border-subtle text-text-main text-sm focus:outline-none focus:border-blue-500 transition-colors resize-none"
						></textarea>
						<button
							id="ai-chat-send"
							class="flex-shrink-0 p-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors cursor-pointer border-none disabled:opacity-50 disabled:cursor-not-allowed"
							aria-label="Enviar pregunta"
						>
							<span class="material-icons" style="font-size:1.1rem;">send</span>
						</button>
					</div>
				</div>

			</div>
		</div>
	</div>
<style is:global>
  .ai-chat-bubble-user {
    max-width: 85%;
    padding: 0.5rem 0.75rem;
    border-radius: 1rem 1rem 0.25rem 1rem;
    background: rgb(37 99 235);
    color: white;
    font-size: 0.875rem;
    line-height: 1.5;
    word-break: break-word;
  }
  .ai-chat-bubble-ai {
    max-width: 85%;
    padding: 0.5rem 0.75rem;
    border-radius: 1rem 1rem 1rem 0.25rem;
    background: rgb(var(--bg-surface-hover));
    border: 1px solid rgb(var(--border-subtle));
    color: rgb(var(--text-main));
    font-size: 0.875rem;
    line-height: 1.5;
    word-break: break-word;
  }
</style>
</BaseLayout>

<style>
	@reference "../styles/global.css";
	
	.btn {
		@apply mt-[1em] px-[1.2em] py-[0.6em] text-[1em] border border-border-subtle text-text-main rounded-[5px] cursor-pointer whitespace-nowrap bg-surface hover:bg-surface-hover transition-colors shadow-subtle hover:shadow-sm font-medium;
	}
	.btn-primary {
		@apply mt-[1em] px-[1.2em] py-[0.6em] text-[1em] border-none text-white rounded-[5px] cursor-pointer whitespace-nowrap bg-blue-600 hover:bg-blue-700 transition-colors shadow-sm hover:shadow font-medium disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-blue-600 disabled:hover:shadow-none;
	}
	.btn-secondary {
		@apply px-[1.2em] py-[0.6em] text-[1em] border-2 border-border-subtle text-text-main rounded-[5px] cursor-pointer whitespace-nowrap bg-transparent hover:bg-surface-hover transition-colors font-medium;
	}
	.btn-tertiary {
		@apply px-[1.2em] py-[0.6em] text-[1em] border-none text-text-muted hover:text-text-main rounded-[5px] cursor-pointer whitespace-nowrap bg-transparent hover:bg-surface-hover transition-colors font-medium;
	}
	.btn-ghost {
		@apply px-[1em] py-[0.5em] text-[0.9em] border-none text-text-muted hover:text-text-main rounded-[5px] cursor-pointer whitespace-nowrap bg-transparent hover:bg-surface-hover transition-colors font-medium;
	}

	.btn-explicar-ia {
		@apply flex items-center justify-center gap-1.5 px-4 py-2 text-sm font-semibold
			   border border-blue-400/60 text-blue-500 dark:text-blue-400
			   rounded-lg cursor-pointer transition-all bg-transparent
			   hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:border-blue-500
			   hover:shadow-sm hover:-translate-y-px;
	}
	.btn-explicar-ia:disabled {
		@apply opacity-40 cursor-not-allowed pointer-events-none hover:bg-transparent hover:border-blue-400/60 hover:shadow-none hover:translate-y-0;
	}

	@media (max-width: 767px) {
		#app {
			@apply w-[95%]! p-[15px]! mt-[70px]!;
		}
		.btn, .btn-secondary, .btn-tertiary, .btn-ghost {
			@apply m-[5px]! px-[12px]! py-[8px]! text-[0.9em]!;
		}
		.btn-primary {
			@apply w-full! m-0! mb-[8px]! min-h-[52px]! text-[1.05em]! rounded-[8px]!;
		}
		.btn-explicar-ia {
			@apply w-full! m-0!;
		}
		#action-buttons-container {
			@apply gap-[5px]! pt-[15px]!;
		}
	}
	
	@media (max-width: 480px) {
		.btn, .btn-primary, .btn-secondary, .btn-tertiary, .btn-ghost {
			@apply text-[0.9em]!;
		}
		.btn-primary {
			@apply min-h-[56px]! text-[1.05em]!;
		}
	}

	/* ── Botón Generar quiz con IA ─────────────────────────────────── */
	.btn-aigen {
		@apply flex items-center gap-1.5 text-violet-600 dark:text-violet-400
			   border-violet-400/60 dark:border-violet-500/50
			   hover:bg-violet-50 dark:hover:bg-violet-900/20 hover:border-violet-500;
	}

	/* ── Modal AI Generate: entrada animada ──────────────────────────── */
	.aigen-modal-box {
		opacity: 0;
		transform: translateY(16px) scale(0.97);
		transition: opacity 0.24s ease, transform 0.24s ease;
	}
	#aigen-modal:not(.hidden) .aigen-modal-box {
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	/* ── Botón "Generar preguntas" ────────────────────────────────────── */
	.aigen-generate-btn {
		background: linear-gradient(135deg, #7c3aed, #6d28d9);
		color: white;
		box-shadow: 0 4px 14px rgba(124, 58, 237, 0.35);
	}
	.aigen-generate-btn:hover {
		background: linear-gradient(135deg, #6d28d9, #5b21b6);
		box-shadow: 0 6px 20px rgba(124, 58, 237, 0.45);
		transform: translateY(-1px);
	}
	.aigen-generate-btn:active {
		transform: translateY(0);
		box-shadow: 0 2px 8px rgba(124, 58, 237, 0.3);
	}

	/* ── Slider personalizado ─────────────────────────────────────────── */
	.aigen-slider {
		-webkit-appearance: none;
		appearance: none;
		width: 100%;
		height: 8px;
		border-radius: 4px;
		cursor: pointer;
		outline: none;
		background: linear-gradient(
			to right,
			#7c3aed var(--aigen-fill, 8%),
			rgb(var(--border-subtle)) var(--aigen-fill, 8%)
		);
		transition: background 0.1s ease;
	}
	.aigen-slider::-webkit-slider-thumb {
		-webkit-appearance: none;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		background: #7c3aed;
		border: 3px solid rgb(var(--bg-surface));
		box-shadow: 0 0 0 2px #7c3aed, 0 2px 8px rgba(124, 58, 237, 0.45);
		cursor: pointer;
		transition: transform 0.12s ease, box-shadow 0.12s ease;
	}
	.aigen-slider:hover::-webkit-slider-thumb,
	.aigen-slider:focus::-webkit-slider-thumb {
		transform: scale(1.12);
