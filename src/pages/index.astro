---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>

	<!-- ─── Modal "anuncio" ─────────────────────────────────────────────── -->
	<div id="welcome-modal-overlay" class="fixed inset-0 z-[200] flex items-center justify-center bg-black/80 backdrop-blur-sm px-4">
		<div class="relative w-full max-w-lg rounded-2xl overflow-hidden shadow-2xl">
			<div class="h-1.5 w-full bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500"></div>
			<div class="bg-surface px-8 py-8 text-center">
				<div class="flex justify-center mb-5">
					<span class="material-icons text-[3.2rem] text-blue-500">volunteer_activism</span>
				</div>
				<h2 class="font-heading text-[1.6em] font-extrabold text-text-main m-0 mb-5 leading-tight">
					Esta web existe porque alguien, antes que tú, decidió no ser egoísta
				</h2>
				<p class="text-text-muted text-[0.97em] leading-relaxed m-0">
					Alguien se sentó a recopilar preguntas de exámenes sin que nadie se lo pidiera, solo para que tú pudieras llegar aquí y prepararte mejor. No te conocían. Lo hicieron igualmente.
				</p>
				<p class="text-text-main font-semibold text-[1.02em] leading-relaxed m-0 mt-5">
					Cuando termines tus exámenes, <span class="text-blue-400">no seas el último eslabón</span>.<br/>
					Envía tus preguntas. Ayuda al que viene detrás. Esa cadena eres tú ahora.
				</p>
				<div class="flex justify-end mt-8">
					<button
						id="welcome-modal-skip"
						disabled
						class="flex items-center gap-2 px-5 py-2 rounded-md border border-border-subtle bg-surface-hover text-text-muted text-[0.88em] font-medium cursor-not-allowed transition-all select-none"
					>
						Lo entiendo
						<span id="welcome-skip-countdown" class="opacity-60">· 5</span>
					</button>
				</div>
			</div>
		</div>
	</div>

	<div id="main-container" class="flex flex-col items-center justify-center m-auto w-full">
		<div id="app" class="relative w-max max-w-[95vw] text-center bg-surface shadow-md shadow-black/5 rounded-[5px] px-[40px] py-[30px] mx-auto my-[20px] box-border border border-border-subtle">

			<a
				href="mailto:informaticatestua@gmail.com?subject=Preguntas%20para%20a%C3%B1adir%20a%20Inform%C3%A1tica%20Test%20UA"
				id="contribute-banner"
				class="group relative hidden lg:block overflow-hidden rounded-[10px] mb-6 px-5 py-4 text-left border border-blue-400/40 dark:border-blue-400/30 bg-gradient-to-r from-blue-500 via-indigo-500 to-purple-500 shadow-md hover:shadow-lg hover:-translate-y-0.5 transition-all"
			>
				<span class="pointer-events-none absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_top_right,white,transparent_60%)]"></span>
				<div class="relative flex items-center gap-3 flex-wrap">
					<span class="material-icons text-white text-[1.8em] drop-shadow">mark_email_unread</span>
					<div class="flex-1 min-w-[200px]">
						<p class="m-0 text-white font-heading font-bold text-[1.05em] leading-tight">
							¿Tienes preguntas de otras asignaturas?
						</p>
						<p class="m-0 mt-1 text-white/90 text-[0.92em] leading-snug">
							Envíamelas a
							<span class="font-semibold underline decoration-white/60 underline-offset-2">informaticatestua@gmail.com</span>
							y las añado a la web.
						</p>
					</div>
					<span class="material-icons text-white/90 group-hover:translate-x-1 transition-transform" aria-hidden="true">arrow_forward</span>
				</div>
			</a>

			<div id="asignaturas-container">
				
				<!-- Rama Software -->
				<h3 class="text-[1.2em] font-heading font-semibold mt-6 mb-2">Rama Software</h3>
				<div class="asignaturas grid grid-cols-[1fr_2px_1fr] gap-[20px] w-full mb-[20px] items-center">
					<div class="group-left flex justify-end gap-[10px] flex-wrap">
						<button id="dca" class="btn">DCA</button>
						<button id="mads" class="btn">MADS NO OFICIAL</button>
					</div>
					<div class="separator w-[2px] h-[35px] bg-border-subtle mx-auto"></div>
					<div class="group-right flex justify-start gap-[10px] flex-wrap">
						<button id="gcs" class="btn">GCS</button>
						<button id="sds" class="btn">SDS NO OFICIAL</button>
					</div>
				</div>

				<div id="mads-sublist" class="hidden bg-surface-hover p-[20px] rounded-[8px] border border-border-subtle shadow-sm flex flex-col items-center mb-[20px] transition-all">
					<h4 class="mt-0 mb-[15px] font-semibold text-text-muted">Exámenes MADS</h4>
					<div class="asignaturas listaoculta flex justify-center items-center flex-wrap gap-[15px] w-full">
						<button id="MADS-NO-OFICIAL-P1" class="btn-primary">MADS NO OFICIAL P1</button>
						<button id="MADS-NO-OFICIAL-P2" class="btn-primary">MADS NO OFICIAL P2</button>
					</div>
				</div>

				<div id="dca-sublist" class="hidden bg-surface-hover p-[20px] rounded-[8px] border border-border-subtle shadow-sm flex flex-col items-center mb-[20px] transition-all">
					<h4 class="mt-0 mb-[15px] font-semibold text-text-muted">Exámenes DCA</h4>
					<div class="asignaturas listaoculta flex justify-center items-center flex-wrap gap-[15px] w-full">
						<button id="dca-oficial" class="btn-primary">DCA OFICIAL</button>
						<button id="dca-NO-OFICIAL" class="btn-primary">DCA NO OFICIAL</button>
					</div>
				</div>

				<div id="gcs-sublist" class="hidden bg-surface-hover p-[20px] rounded-[8px] border border-border-subtle shadow-sm flex flex-col items-center mb-[20px] transition-all">
					<h4 class="mt-0 mb-[15px] font-semibold text-text-muted">Exámenes GCS</h4>
					<div class="asignaturas listaoculta flex justify-center items-center flex-wrap gap-[15px] w-full">
						<button id="gcsp1nooficial" class="btn-primary">GCS P1 NO OFICIAL 2025</button>
						<button id="gcsp1old" class="btn-primary">GCS P1 old 2024</button>
						<button id="gcsp2old" class="btn-primary">GCS P2 old 2024</button>
					</div>
				</div>

				<div id="sds-sublist" class="hidden bg-surface-hover p-[20px] rounded-[8px] border border-border-subtle shadow-sm flex flex-col items-center mb-[20px] transition-all">
					<h4 class="mt-0 mb-[15px] font-semibold text-text-muted">Exámenes SDS</h4>
					<div class="asignaturas listaoculta flex justify-center items-center flex-wrap gap-[15px] w-full max-w-[800px]">
						<button id="sdsfull" class="btn-primary">SDS FULL</button>
						<button id="sds01-presentacion" class="btn-primary">sds01 presentacion</button>
						<button id="sds02-introgo" class="btn-primary">sds02 introgo</button>
						<button id="sds03-introcripto" class="btn-primary">sds03 introcripto</button>
						<button id="sds04-aleatorios" class="btn-primary">sds04 aleatorios</button>
						<button id="sds05-flujo" class="btn-primary">sds05 flujo</button>
						<button id="sds06-bloque" class="btn-primary">sds06 bloque</button>
						<button id="sds07-hash" class="btn-primary">sds07 hash</button>
						<button id="sds08-publica" class="btn-primary">sds08 publica</button>
						<button id="sds09-transporte" class="btn-primary">sds09 transporte</button>
						<button id="sds10-ejercicios" class="btn-primary">sds10 ejercicios</button>
						<button id="sds11-malware" class="btn-primary">sds11 malware</button>
						<button id="sds12-ataques" class="btn-primary">sds12 ataques</button>
						<button id="sds13-wireless" class="btn-primary">sds13 wireless</button>
						<button id="sds14-recomendaciones" class="btn-primary">sds14 recomendaciones</button>
					</div>
				</div>

				<!-- Tercer Curso -->
				<h3 class="text-[1.2em] font-heading font-semibold mt-6 mb-2">Tercer Curso</h3>
				<div class="asignaturas grid grid-cols-[1fr_2px_1fr] gap-[20px] w-full mb-[20px] items-center">
					<div class="group-left flex justify-end gap-[10px] flex-wrap">
						<button id="dss" class="btn">DSS</button>
						<button id="gpi" class="btn">GPI</button>
						<button id="ic-p1" class="btn">IC P1</button>
					</div>
					<div class="separator w-[2px] h-[35px] bg-border-subtle mx-auto"></div>
					<div class="group-right flex justify-start gap-[10px] flex-wrap">
						<button id="taes-definitivo" class="btn">TAES DEFINITIVO OLD</button>
						<button id="ppss" class="btn">PPSS</button>
					</div>
				</div>

				<div id="ppss-sublist" class="hidden bg-surface-hover p-[20px] rounded-[8px] border border-border-subtle shadow-sm flex flex-col items-center mb-[20px] transition-all">
					<h4 class="mt-0 mb-[15px] font-semibold text-text-muted">Exámenes PPSS</h4>
					<div class="asignaturas listaoculta flex justify-center items-center flex-wrap gap-[15px] w-full">
						<button id="ppss-p1" class="btn-primary">PPSS P1</button>
						<button id="ppss-p2" class="btn-primary">PPSS P2</button>
						<button id="ppss-C4-2025" class="btn-primary">ppss C4 2025</button>
					</div>
				</div>

				<!-- Segundo Curso -->
				<h3 class="text-[1.2em] font-heading font-semibold mt-6 mb-2">Segundo Curso</h3>
				<div class="asignaturas grid grid-cols-[1fr_2px_1fr] gap-[20px] w-full mb-[20px] items-center">
					<div class="group-left flex justify-end gap-[10px] flex-wrap">
						<button id="redes" class="btn">REDES</button>
					</div>
					<div class="separator w-[2px] h-[35px] bg-border-subtle mx-auto"></div>
					<div class="group-right flex justify-start gap-[10px] flex-wrap">
						<button id="ada" class="btn">ADA</button>
						<button id="ped" class="btn">PED</button>
						<button id="ac" class="btn">AC</button>
						<button id="hada" class="btn">HADA</button>
					</div>
				</div>

				<div id="ada-sublist" class="hidden bg-surface-hover p-[20px] rounded-[8px] border border-border-subtle shadow-sm flex flex-col items-center mb-[20px] transition-all">
					<h4 class="mt-0 mb-[15px] font-semibold text-text-muted">Exámenes ADA</h4>
					<div class="asignaturas listaoculta flex justify-center items-center flex-wrap gap-[15px] w-full">
						<button id="ada-p1" class="btn-primary">ada p1</button>
						<button id="ada-p2" class="btn-primary">ada p2</button>
						<button id="ada-full" class="btn-primary">ada full</button>
					</div>
				</div>

				<div id="ac-sublist" class="hidden bg-surface-hover p-[20px] rounded-[8px] border border-border-subtle shadow-sm flex flex-col items-center mb-[20px] transition-all">
					<h4 class="mt-0 mb-[15px] font-semibold text-text-muted">Exámenes AC</h4>
					<div class="asignaturas listaoculta flex justify-center items-center flex-wrap gap-[15px] w-full">
						<button id="ac_CP-F2" class="btn-primary">ac CP F2</button>
						<button id="ac_CP-F3" class="btn-primary">ac CP F3</button>
						<button id="ac_CT1-2" class="btn-primary">ac CT1 2</button>
						<button id="ac_CT3-4" class="btn-primary">ac CT3 4</button>
					</div>
				</div>

				<div id="redes-sublist" class="hidden bg-surface-hover p-[20px] rounded-[8px] border border-border-subtle shadow-sm flex flex-col items-center mb-[20px] transition-all">
					<h4 class="mt-0 mb-[15px] font-semibold text-text-muted">Exámenes REDES</h4>
					<div class="asignaturas listaoculta flex justify-center items-center flex-wrap gap-[15px] w-full">
						<button id="redes_full" class="btn-primary">redes full</button>
						<button id="redesEnero2324" class="btn-primary">redes Enero 23 24</button>
						<button id="redesEnero2425" class="btn-primary">redes Enero 24 25</button>
						<button id="redesJulio2425" class="btn-primary">redes Julio 24 25</button>
						<button id="redesEnero2526" class="btn-primary">redes Enero 25 26</button>
					</div>
				</div>

				<!-- Primer Curso -->
				<h3 class="text-[1.2em] font-heading font-semibold mt-6 mb-2">Primer Curso</h3>
				<div id="asignatura-centrada" class="flex justify-center w-full mb-[20px]">
					<button id="sti" class="btn">STI</button>
				</div>
				
			</div>
		</div>
	</div>

	<script>
		(function () {
			const overlay  = document.getElementById("welcome-modal-overlay");
			const skipBtn  = document.getElementById("welcome-modal-skip");
			const countdown = document.getElementById("welcome-skip-countdown");
			if (!overlay || !skipBtn || !countdown) return;

			let secs = 5;
			const tick = setInterval(() => {
				secs--;
				if (secs <= 0) {
					clearInterval(tick);
					countdown.textContent = "";
					skipBtn.disabled = false;
					skipBtn.classList.remove("cursor-not-allowed", "text-text-muted");
					skipBtn.classList.add("cursor-pointer", "text-text-main", "hover:bg-surface");
				} else {
					countdown.textContent = `· ${secs}`;
				}
			}, 1000);

			skipBtn.addEventListener("click", () => {
				overlay.classList.add("hidden");
			});
		})();

		document.getElementById("asignaturas-container")?.addEventListener("click", function (e) {
			const target = e.target as HTMLElement;
			if (target.tagName === "BUTTON") {
				const idBoton = target.id;
				if (!idBoton) return;
				
				const sublist = document.getElementById(idBoton + "-sublist");

				if (sublist) {
					const sublistas = document.querySelectorAll('[id$="-sublist"]');
					sublistas.forEach((sub) => {
						if (sub.id !== idBoton + "-sublist") sub.classList.add("hidden");
					});
					sublist.classList.toggle("hidden");
				} else {
					window.location.href = `/${idBoton}`;
				}
			}
		});
	</script>
</BaseLayout>

<style>
	@reference "../styles/global.css";
	/* Optamos por usar @apply dentro de un scope de Astro para no tener un HTML tan ensordecedor */
	.btn {
		@apply mt-[0px] px-[1.2em] py-[0.6em] text-[1em] border border-border-subtle text-text-main rounded-[5px] cursor-pointer whitespace-nowrap bg-surface hover:bg-surface-hover transition-colors shadow-subtle hover:shadow-sm font-medium;
	}
	.btn-primary {
		@apply mt-[0px] px-[1.2em] py-[0.6em] text-[1em] border-none text-white rounded-[5px] cursor-pointer whitespace-nowrap bg-blue-600 hover:bg-blue-700 transition-colors shadow-sm hover:shadow font-medium;
	}
	
	/* Aplicar bordes suaves a los botones */
	@media (max-width: 767px) {
		.asignaturas {
			@apply flex! flex-col! items-center!;
		}
		.group-left, .group-right {
			@apply w-[100%]! flex! flex-wrap! justify-center!;
		}
		.separator {
			@apply w-[100%]! h-[1px]! my-[10px]!;
		}
		.btn, .btn-primary {
			@apply m-[5px]! px-[12px]! py-[8px]! text-[0.9em]! min-w-[80px]!;
		}
		#app {
			@apply w-[95%]! p-[15px]! mt-[70px]!;
		}
	}
	
	@media (max-width: 480px) {
		h1 {
			@apply text-[1.5em]!;
		}
		h3 {
			@apply text-[1.2em]!;
		}
		.btn, .btn-primary {
			@apply text-[0.8em]! min-w-[70px]!;
		}
	}
</style>
