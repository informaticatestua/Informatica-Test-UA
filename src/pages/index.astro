---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
	<div id="main-container" class="layout-container animate-fade-in">
		<div id="app" class="flex flex-col gap-12">
			<header class="text-center md:text-left">
				<h1 id="app-title" class="font-heading text-4xl md:text-5xl font-bold tracking-tight text-text-main mb-4">
					Seleccione una asignatura
				</h1>
				<p class="text-text-muted text-lg md:text-xl max-w-2xl text-balance">
					Explora los distintos exámenes y test clasificados por curso y rama para poner a prueba tus conocimientos.
				</p>
			</header>

			<div id="asignaturas-container" class="flex flex-col gap-12">
				
				<!-- RAMA SOFTWARE -->
				<section class="group">
					<h3 class="section-title">Rama Software</h3>
					<div class="asignaturas grid grid-cols-1 md:grid-cols-[1fr_auto_1fr] gap-4 md:gap-8 items-start">
						<div class="group-left flex flex-col gap-3">
							<button id="dca" class="ui-button">DCA</button>
							<button id="mads" class="ui-button">MADS NO OFICIAL</button>
						</div>
						
						<div class="separator hidden md:block w-px self-stretch bg-border-subtle"></div>
						<div class="separator block md:hidden w-full h-px bg-border-subtle my-2"></div>
						
						<div class="group-right flex flex-col gap-3">
							<button id="gcs" class="ui-button">GCS</button>
							<button id="sds" class="ui-button">SDS NO OFICIAL</button>
						</div>
					</div>

					<!-- Sublistas Rama Software -->
					<div id="mads-sublist" class="hidden mt-6 bg-surface p-5 sm:p-6 rounded-2xl border border-border-subtle shadow-subtle animate-fade-in-up">
						<h4 class="text-xs font-bold text-text-muted mb-4 uppercase tracking-wider">Exámenes MADS</h4>
						<div class="asignaturas listaoculta grid grid-cols-1 sm:grid-cols-2 gap-3">
							<button id="MADS-NO-OFICIAL-P1" class="ui-button-primary">MADS NO OFICIAL P1</button>
							<button id="MADS-NO-OFICIAL-P2" class="ui-button-primary">MADS NO OFICIAL P2</button>
						</div>
					</div>

					<div id="dca-sublist" class="hidden mt-6 bg-surface p-5 sm:p-6 rounded-2xl border border-border-subtle shadow-subtle animate-fade-in-up">
						<h4 class="text-xs font-bold text-text-muted mb-4 uppercase tracking-wider">Exámenes DCA</h4>
						<div class="asignaturas listaoculta grid grid-cols-1 sm:grid-cols-2 gap-3">
							<button id="dca-oficial" class="ui-button-primary">DCA OFICIAL</button>
							<button id="dca-NO-OFICIAL" class="ui-button-primary">DCA NO OFICIAL</button>
						</div>
					</div>

					<div id="gcs-sublist" class="hidden mt-6 bg-surface p-5 sm:p-6 rounded-2xl border border-border-subtle shadow-subtle animate-fade-in-up">
						<h4 class="text-xs font-bold text-text-muted mb-4 uppercase tracking-wider">Exámenes GCS</h4>
						<div class="asignaturas listaoculta grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
							<button id="gcsp1nooficial" class="ui-button-primary">GCS P1 NO OFICIAL 2025</button>
							<button id="gcsp1old" class="ui-button-primary">GCS P1 old 2024</button>
							<button id="gcsp2old" class="ui-button-primary">GCS P2 old 2024</button>
						</div>
					</div>

					<div id="sds-sublist" class="hidden mt-6 bg-surface p-5 sm:p-6 rounded-2xl border border-border-subtle shadow-subtle animate-fade-in-up">
						<h4 class="text-xs font-bold text-text-muted mb-4 uppercase tracking-wider">Exámenes SDS</h4>
						<div class="asignaturas listaoculta grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
							<button id="sdsfull" class="ui-button-primary">SDS FULL</button>
							<button id="sds01-presentacion" class="ui-button-primary">sds01 presentacion</button>
							<button id="sds02-introgo" class="ui-button-primary">sds02 introgo</button>
							<button id="sds03-introcripto" class="ui-button-primary">sds03 introcripto</button>
							<button id="sds04-aleatorios" class="ui-button-primary">sds04 aleatorios</button>
							<button id="sds05-flujo" class="ui-button-primary">sds05 flujo</button>
							<button id="sds06-bloque" class="ui-button-primary">sds06 bloque</button>
							<button id="sds07-hash" class="ui-button-primary">sds07 hash</button>
							<button id="sds08-publica" class="ui-button-primary">sds08 publica</button>
							<button id="sds09-transporte" class="ui-button-primary">sds09 transporte</button>
							<button id="sds10-ejercicios" class="ui-button-primary">sds10 ejercicios</button>
							<button id="sds11-malware" class="ui-button-primary">sds11 malware</button>
							<button id="sds12-ataques" class="ui-button-primary">sds12 ataques</button>
							<button id="sds13-wireless" class="ui-button-primary">sds13 wireless</button>
							<button id="sds14-recomendaciones" class="ui-button-primary">sds14 recomendaciones</button>
						</div>
					</div>
				</section>

				<div class="ui-separator"></div>

				<!-- TERCER CURSO -->
				<section class="group">
					<h3 class="section-title">Tercer Curso</h3>
					<div class="asignaturas grid grid-cols-1 md:grid-cols-[1fr_auto_1fr] gap-4 md:gap-8 items-start">
						<div class="group-left flex flex-col gap-3">
							<button id="dss" class="ui-button">DSS</button>
							<button id="gpi" class="ui-button">GPI</button>
							<button id="ic-p1" class="ui-button">IC P1</button>
						</div>
						
						<div class="separator hidden md:block w-px self-stretch bg-border-subtle"></div>
						<div class="separator block md:hidden w-full h-px bg-border-subtle my-2"></div>
						
						<div class="group-right flex flex-col gap-3">
							<button id="taes-definitivo" class="ui-button">TAES DEFINITIVO OLD</button>
							<button id="ppss" class="ui-button">PPSS</button>
						</div>
					</div>

					<div id="ppss-sublist" class="hidden mt-6 bg-surface p-5 sm:p-6 rounded-2xl border border-border-subtle shadow-subtle animate-fade-in-up">
						<h4 class="text-xs font-bold text-text-muted mb-4 uppercase tracking-wider">Exámenes PPSS</h4>
						<div class="asignaturas listaoculta grid grid-cols-1 sm:grid-cols-2 gap-3">
							<button id="ppss-p1" class="ui-button-primary">PPSS P1</button>
							<button id="ppss-p2" class="ui-button-primary">PPSS P2</button>
						</div>
					</div>
				</section>

				<div class="ui-separator"></div>

				<!-- SEGUNDO CURSO -->
				<section class="group">
					<h3 class="section-title">Segundo Curso</h3>
					<div class="asignaturas grid grid-cols-1 md:grid-cols-[1fr_auto_1fr] gap-4 md:gap-8 items-start">
						<div class="group-left flex flex-col gap-3">
							<button id="redes" class="ui-button">REDES</button>
						</div>
						
						<div class="separator hidden md:block w-px self-stretch bg-border-subtle"></div>
						<div class="separator block md:hidden w-full h-px bg-border-subtle my-2"></div>
						
						<div class="group-right flex flex-col gap-3">
							<button id="ada" class="ui-button">ADA</button>
							<button id="ped" class="ui-button">PED</button>
							<button id="ac" class="ui-button">AC</button>
							<button id="hada" class="ui-button">HADA</button>
						</div>
					</div>

					<div id="ada-sublist" class="hidden mt-6 bg-surface p-5 sm:p-6 rounded-2xl border border-border-subtle shadow-subtle animate-fade-in-up">
						<h4 class="text-xs font-bold text-text-muted mb-4 uppercase tracking-wider">Exámenes ADA</h4>
						<div class="asignaturas listaoculta grid grid-cols-1 sm:grid-cols-3 gap-3">
							<button id="ada-p1" class="ui-button-primary">ada p1</button>
							<button id="ada-p2" class="ui-button-primary">ada p2</button>
							<button id="ada-full" class="ui-button-primary">ada full</button>
						</div>
					</div>

					<div id="ac-sublist" class="hidden mt-6 bg-surface p-5 sm:p-6 rounded-2xl border border-border-subtle shadow-subtle animate-fade-in-up">
						<h4 class="text-xs font-bold text-text-muted mb-4 uppercase tracking-wider">Exámenes AC</h4>
						<div class="asignaturas listaoculta grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
							<button id="ac_CP-F2" class="ui-button-primary">ac CP F2</button>
							<button id="ac_CP-F3" class="ui-button-primary">ac CP F3</button>
							<button id="ac_CT1-2" class="ui-button-primary">ac CT1 2</button>
							<button id="ac_CT3-4" class="ui-button-primary">ac CT3 4</button>
						</div>
					</div>

					<div id="redes-sublist" class="hidden mt-6 bg-surface p-5 sm:p-6 rounded-2xl border border-border-subtle shadow-subtle animate-fade-in-up">
						<h4 class="text-xs font-bold text-text-muted mb-4 uppercase tracking-wider">Exámenes REDES</h4>
						<div class="asignaturas listaoculta grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
							<button id="redes_full" class="ui-button-primary">redes full</button>
							<button id="redesEnero2324" class="ui-button-primary">redes Enero 23 24</button>
							<button id="redesEnero2425" class="ui-button-primary">redes Enero 24 25</button>
							<button id="redesJulio2425" class="ui-button-primary">redes Julio 24 25</button>
							<button id="redesEnero2526" class="ui-button-primary">redes Enero 25 26</button>
						</div>
					</div>
				</section>

				<div class="ui-separator"></div>

				<!-- PRIMER CURSO -->
				<section class="group mb-12">
					<h3 class="section-title">Primer Curso</h3>
					<div id="asignatura-centrada" class="max-w-md mx-auto w-full">
						<button id="sti" class="ui-button w-full">STI</button>
					</div>
				</section>

			</div>
		</div>
	</div>

	<script>
		// Lógica delegada de eventos para los botones
		const container = document.getElementById("asignaturas-container");
		
		if (container) {
			container.addEventListener("click", function (e) {
				const target = e.target as HTMLElement;
				// Asegurarnos de capturar el clic incluso si se hace clic en un hijo del botón
				const button = target.closest("button");
				
				if (button && container.contains(button)) {
					const idBoton = button.id;
					
					// Prevenir lógica si el botón no tiene ID (ej. el toggle de tema podría colarse si estuviera dentro, pero no lo está)
					if (!idBoton) return;

					const sublist = document.getElementById(idBoton + "-sublist");

					if (sublist) {
						// Alternar menú ocultando los demás
						const sublistas = document.querySelectorAll('[id$="-sublist"]');
						sublistas.forEach((sub) => {
							if (sub.id !== idBoton + "-sublist") {
								sub.classList.add("hidden");
							}
						});
						sublist.classList.toggle("hidden");
					} else {
						// REDIRECCIÓN A LA URL LIMPIA
						window.location.href = `/${idBoton}`;
					}
				}
			});
		}
	</script>
</BaseLayout>
