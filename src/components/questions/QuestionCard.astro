---
interface Props {
  question: {
    id: string;
    text: string;
    options: { id: string; text: string; isCorrect: boolean }[];
    imagePath?: string;
    mathSupported: boolean;
  };
  index: number;
}

const { question, index } = Astro.props;
---

<div class="bg-white rounded-2xl p-6 shadow-md border border-gray-100 mb-6" data-question-id={question.id}>
  <div class="flex items-start space-x-4 mb-6">
    <span class="bg-primary bg-opacity-10 text-primary font-bold rounded-full w-8 h-8 flex items-center justify-center flex-shrink-0">
      {index}
    </span>
    <div class="flex-grow">
      <p class="text-lg text-gray-800 font-medium leading-relaxed question-text mb-4">
        {question.text}
      </p>
      {question.imagePath && (
        <div class="mb-6 rounded-2xl overflow-hidden border border-gray-100 bg-gray-50 flex justify-center">
          <img 
            src={question.imagePath} 
            alt="Diagrama de la pregunta" 
            class="max-h-80 object-contain"
          />
        </div>
      )}
    </div>
  </div>

  <div class="space-y-3">
    {question.options.map((option) => (
      <button 
        class="w-full text-left p-4 rounded-xl border border-gray-200 hover:border-primary hover:bg-primary hover:bg-opacity-5 transition-all group relative flex items-center space-x-3 option-btn"
        data-correct={option.isCorrect}
      >
        <span class="w-6 h-6 rounded-full border-2 border-gray-300 group-hover:border-primary flex-shrink-0 flex items-center justify-center text-xs font-bold text-gray-400 group-hover:text-primary uppercase">
          {option.id}
        </span>
        <span class="text-gray-700 flex-grow">{option.text}</span>
        
        <span class="material-icons-outlined hidden correct-icon text-green-500">check_circle</span>
        <span class="material-icons-outlined hidden incorrect-icon text-red-500">cancel</span>
      </button>
    ))}
  </div>

  <div class="mt-6 pt-6 border-t border-gray-50 flex justify-between items-center">
    <button class="text-sm text-gray-400 hover:text-gray-600 flex items-center space-x-1" onclick={`reportQuestion('${question.id}')`}>
      <span class="material-icons-outlined text-base">report_problem</span>
      <span>Reportar error</span>
    </button>
    <div class="explanation hidden text-sm text-gray-500 italic bg-blue-50 p-3 rounded-lg w-full mt-4">
      {/* Explanation logic will be added here or via JS */}
    </div>
  </div>
</div>

<script>
  // Shared logic for question interactions can be here or in a manager
</script>
