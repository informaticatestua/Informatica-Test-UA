---
---
  <header class="sticky top-0 z-50 glass border-b border-white/5 px-6 py-4 lg:px-20 transition-all duration-300">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-xl overflow-hidden shadow-lg group-hover:shadow-primary/30 transition-all bg-white/5 flex items-center justify-center border border-white/10 group-hover:border-primary/50">
          <img src="/logo.png" alt="Logo Informática Test UA" class="w-full h-full object-contain p-1" />
        </div>
        <h2 class="text-xl font-bold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-white to-slate-400">
          Informática Test <span class="text-primary">UA</span>
        </h2>
      </a>
      
      <nav class="hidden md:flex items-center gap-8">
        <a class="text-sm font-medium hover:text-primary transition-colors text-slate-400" href="/">Asignaturas</a>
        <a class="text-sm font-medium hover:text-primary transition-colors text-slate-400" href="#">Exámenes</a>
        <a class="text-sm font-medium hover:text-primary transition-colors text-slate-400" href="#">Comunidad</a>
      </nav>
      
      <div class="flex items-center gap-4">
        <button class="bg-primary hover:bg-primary/90 text-white px-5 py-2.5 rounded-lg text-sm font-bold transition-all shadow-lg shadow-primary/20 active:scale-95">
          Contribuir
        </button>
      </div>
    </div>
  </header>
