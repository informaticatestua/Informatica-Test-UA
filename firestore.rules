service cloud.firestore {
  match /databases/{database}/documents {
    // Subjects, Modules, and Questions: Public read-only (root collections)
    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if false; 
    }
    match /modules/{moduleId} {
      allow read: if true;
      allow write: if false;
    }
    match /questions/{questionId} {
      allow read: if true;
      allow write: if false;
    }

    // Nested structure used by the app:
    // courses/{courseId}/subjects/{subjectId}/modules/{moduleId}/questions/{questionId}
    match /courses/{courseId}/subjects/{subjectId} {
      allow read: if true;
      allow write: if false;
    }
    match /courses/{courseId}/subjects/{subjectId}/modules/{moduleId} {
      allow read: if true;
      allow write: if false;
    }
    match /courses/{courseId}/subjects/{subjectId}/modules/{moduleId}/questions/{questionId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Reports and Suggestions: Public can create, only admin can manage
    match /reports/{reportId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    match /suggestions/{suggestionId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
