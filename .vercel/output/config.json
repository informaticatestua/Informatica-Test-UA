{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/dashboard/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/update-report/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/update-suggestion/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/report/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/suggest/?$",
			"dest": "_render"
		},
		{
			"src": "^/quiz/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/subject/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/submit-question/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}